<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Quizaty</title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-900 selection:bg-indigo-100 selection:text-indigo-900">

    <%- include('../partials/student_nav', { backUrl: '/student/quizzes', backText: 'العودة للاختبارات' }) %>

    <main class="max-w-4xl mx-auto px-6 py-12">
        <% 
            const quiz = submission.quiz;
            const timeTakenMins = submission.submittedAt ? ((new Date(submission.submittedAt).getTime() - new Date(submission.startedAt).getTime()) / 60000).toFixed(1) : 'غير متوفر';
            const scoreColor = submission.score >= (quiz.totalMarks / 2) ? 'text-emerald-600' : 'text-rose-600';
            let answers = {};
            if (submission.answers) {
                answers = typeof submission.answers === 'string' ? JSON.parse(submission.answers) : submission.answers;
            }
        %>

        <div class="mb-8 text-right">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-black bg-indigo-50 text-indigo-700 mb-3 border border-indigo-100"><%= quiz.title %></span>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">تفاصيل التسليم</h2>
            
            <div class="mt-4 flex flex-wrap gap-4 text-sm text-slate-500 font-medium flex-row-reverse">
                <% if (quiz.showResults) { %>
                    <div class="flex items-center bg-white px-4 py-2 rounded-xl border border-slate-200 shadow-sm flex-row-reverse">
                        <span class="text-xs uppercase text-slate-400 mr-2">الدرجة</span>
                        <span class="text-lg font-black <%= scoreColor %> mr-2"><%= submission.score %></span><span class="text-slate-400">/<%= quiz.totalMarks %></span>
                    </div>
                    <div class="flex items-center bg-white px-4 py-2 rounded-xl border border-slate-200 shadow-sm flex-row-reverse">
                        <span class="text-xs uppercase text-slate-400 mr-2">الوقت المستغرق</span>
                        <span class="text-slate-900 font-bold mr-2"><%= timeTakenMins %> دقيقة</span>
                    </div>
                <% } else { %>
                    <div class="flex items-center bg-amber-50 px-4 py-2 rounded-xl border border-amber-100 shadow-sm flex-row-reverse">
                        <span class="text-xs uppercase text-amber-500 mr-2">الحالة</span>
                        <span class="text-amber-700 font-bold mr-2">بانتظار إصدار النتيجة</span>
                    </div>
                <% } %>
                <div class="flex items-center bg-white px-4 py-2 rounded-xl border border-slate-200 shadow-sm flex-row-reverse">
                    <span class="text-xs uppercase text-slate-400 mr-2">تاريخ التسليم</span>
                    <span class="text-slate-900 mr-2"><%= new Date(submission.submittedAt || submission.startedAt).toLocaleString('ar-EG') %></span>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden min-h-[400px] flex flex-col items-center justify-center p-8 text-center">
            <% if (quiz.showResults) { %>
                <div class="w-full text-right">
                    <div class="px-6 py-5 border-b border-slate-100 bg-slate-50 mb-8 -mx-8 -mt-8">
                        <h3 class="font-black text-slate-900">إجاباتك مقابل الإجابات الصحيحة</h3>
                    </div>
                    
                    <div class="space-y-8">
                        <% quiz.questions.forEach((q, index) => { %>
                            <% 
                                const studentAnswerStr = answers[q.id];
                                const studentAnswer = studentAnswerStr !== undefined ? parseInt(studentAnswerStr) : -1;
                                const isCorrect = studentAnswer === q.correctOption;
                                let badgeColor = 'bg-slate-100 text-slate-600';
                                let badgeText = 'تم التخطي';
                                if (studentAnswer !== -1) {
                                    badgeColor = isCorrect ? 'bg-emerald-100 text-emerald-800' : 'bg-rose-100 text-rose-800';
                                    badgeText = isCorrect ? 'صحيحة' : 'خاطئة';
                                }
                            %>
                            <div class="border border-slate-100 rounded-2xl p-6 bg-white shadow-sm relative overflow-hidden group">
                                <div class="absolute top-0 right-0 w-1.5 h-full <%= isCorrect ? 'bg-emerald-500' : (studentAnswer !== -1 ? 'bg-rose-500' : 'bg-slate-300') %>"></div>
                                <div class="pr-3">
                                    <div class="flex justify-between items-start mb-6">
                                        <h4 class="text-lg font-bold text-slate-900 leading-snug pl-4">
                                            <span class="text-slate-400 ml-1"><%= index + 1 %>.</span> <%= q.questionText %>
                                        </h4>
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-black shrink-0 <%= badgeColor %>"><%= badgeText %></span>
                                    </div>
                                    <% if(q.imageUrl) { %>
                                        <div class="mb-6"><img src="<%= q.imageUrl %>" alt="سؤال" class="max-h-64 rounded-xl border border-slate-200"></div>
                                    <% } %>
                                    <div class="space-y-3 mt-4">
                                        <% q.options.forEach((opt, optIndex) => { %>
                                            <% 
                                                const isSelected = studentAnswer === optIndex;
                                                const isActualCorrect = q.correctOption === optIndex;
                                                let optClass = 'border-slate-100 text-slate-600 bg-white';
                                                let label = '';
                                                if (isSelected && isActualCorrect) {
                                                    optClass = 'border-emerald-500 bg-emerald-50 text-emerald-900 font-bold';
                                                    label = 'إجابتك ✓ صحيحة';
                                                } else if (isSelected && !isActualCorrect) {
                                                    optClass = 'border-rose-300 bg-rose-50 text-rose-900 font-bold';
                                                    label = 'إجابتك ✗';
                                                } else if (isActualCorrect) {
                                                    optClass = 'border-emerald-200 bg-emerald-50 text-emerald-700 border-dashed';
                                                    label = 'الإجابة الصحيحة';
                                                }
                                            %>
                                            <div class="flex items-center justify-between p-4 rounded-xl border text-sm <%= optClass %> flex-row-reverse">
                                                <span class="font-medium"><%= opt %></span>
                                                <% if (label) { %><span class="text-xs font-black"><%= label %></span><% } %>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% } else { %>
                <div class="py-12">
                    <div class="w-20 h-20 bg-amber-100 rounded-3xl flex items-center justify-center mx-auto mb-6 transform -rotate-6">
                        <svg class="w-10 h-10 text-amber-600 rotate-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-2xl font-black text-slate-900 mb-3">النتائج لم تصدر بعد</h3>
                    <p class="text-slate-500 max-w-sm mx-auto leading-relaxed">
                        لقد أكملت الاختبار بنجاح. سيقوم المعلم بإصدار النتائج وتوزيع الدرجات بمجرد انتهاء وقت الاختبار للجميع.
                    </p>
                    <div class="mt-8 flex items-center justify-center gap-2 text-indigo-600 font-bold text-sm">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
                        </span>
                        يتم الآن مراجعة الاختبار
                    </div>
                </div>
            <% } %>
        </div>

        <div class="mt-12">
            <a href="/student/quizzes" class="w-full inline-block text-center bg-slate-900 text-white font-black py-5 rounded-2xl hover:bg-slate-800 transition-all shadow-xl shadow-slate-200">
                العودة لقائمة الاختبارات
            </a>
        </div>
    </main>
</body>
</html>
