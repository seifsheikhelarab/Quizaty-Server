<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | QuizMaster</title>
    <link href="/css/output.css" rel="stylesheet">
</head>
<body class="bg-slate-50 min-h-screen text-slate-900 font-sans">

    <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="/student/dashboard" class="flex items-center space-x-3">
                <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
                </div>
                <h1 class="text-xl font-black tracking-tight text-slate-900">QuizMaster</h1>
            </a>
            <a href="/student/quizzes" class="text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors">Back to Quizzes</a>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">
        <% 
            const quiz = submission.quiz;
            const timeTakenMins = submission.submittedAt ? ((new Date(submission.submittedAt).getTime() - new Date(submission.startedAt).getTime()) / 60000).toFixed(1) : 'N/A';
            const scoreColor = submission.score >= (quiz.totalMarks / 2) ? 'text-emerald-600' : 'text-rose-600';
            let answers = {};
            if (submission.answers) {
                answers = typeof submission.answers === 'string' ? JSON.parse(submission.answers) : submission.answers;
            }
        %>

        <div class="mb-8">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 mb-3"><%= quiz.title %></span>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Submission Details</h2>
            
            <div class="mt-4 flex flex-wrap gap-4 text-sm text-slate-500 font-medium">
                <div class="flex items-center bg-white px-3 py-1.5 rounded-lg border border-slate-200 shadow-sm">
                    <span class="text-xs uppercase text-slate-400 mr-2">Score</span>
                    <span class="text-lg font-black <%= scoreColor %>"><%= submission.score %></span><span class="text-slate-400">/<%= quiz.totalMarks %></span>
                </div>
                <div class="flex items-center bg-white px-3 py-1.5 rounded-lg border border-slate-200 shadow-sm">
                    <span class="text-xs uppercase text-slate-400 mr-2">Time Taken</span>
                    <span class="text-slate-900 font-bold"><%= timeTakenMins %> mins</span>
                </div>
                <div class="flex items-center bg-white px-3 py-1.5 rounded-lg border border-slate-200 shadow-sm">
                    <span class="text-xs uppercase text-slate-400 mr-2">Submitted</span>
                    <span class="text-slate-900"><%= new Date(submission.submittedAt || submission.startedAt).toLocaleString() %></span>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-100 bg-slate-50">
                <h3 class="font-bold text-slate-900">Your Answers vs Correct Answers</h3>
            </div>
            
            <div class="p-6 space-y-8">
                <% quiz.questions.forEach((q, index) => { %>
                    <% 
                        const studentAnswerStr = answers[q.id];
                        const studentAnswer = studentAnswerStr !== undefined ? parseInt(studentAnswerStr) : -1;
                        const isCorrect = studentAnswer === q.correctOption;
                        let badgeColor = 'bg-slate-100 text-slate-600';
                        let badgeText = 'Skipped';
                        if (studentAnswer !== -1) {
                            badgeColor = isCorrect ? 'bg-emerald-100 text-emerald-800' : 'bg-rose-100 text-rose-800';
                            badgeText = isCorrect ? 'Correct' : 'Incorrect';
                        }
                    %>
                    <div class="border border-slate-100 rounded-xl p-5 bg-white shadow-sm relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-1 h-full <%= isCorrect ? 'bg-emerald-500' : (studentAnswer !== -1 ? 'bg-rose-500' : 'bg-slate-300') %>"></div>
                        <div class="pl-3">
                            <div class="flex justify-between items-start mb-4">
                                <h4 class="text-sm font-bold text-slate-900 leading-snug pr-4">
                                    <span class="text-slate-400 mr-1"><%= index + 1 %>.</span> <%= q.questionText %>
                                </h4>
                                <span class="inline-flex items-center px-2 py-1 rounded text-xs font-bold shrink-0 <%= badgeColor %>"><%= badgeText %></span>
                            </div>
                            <% if(q.imageUrl) { %>
                                <div class="mb-4"><img src="<%= q.imageUrl %>" alt="Question" class="max-h-48 rounded border border-slate-200"></div>
                            <% } %>
                            <div class="space-y-2 mt-4">
                                <% q.options.forEach((opt, optIndex) => { %>
                                    <% 
                                        const isSelected = studentAnswer === optIndex;
                                        const isActualCorrect = q.correctOption === optIndex;
                                        let optClass = 'border-slate-200 text-slate-600 bg-white';
                                        let label = '';
                                        if (isSelected && isActualCorrect) {
                                            optClass = 'border-emerald-500 bg-emerald-50 text-emerald-900 font-bold';
                                            label = 'Your answer ✓ Correct';
                                        } else if (isSelected && !isActualCorrect) {
                                            optClass = 'border-rose-300 bg-rose-50 text-rose-900 font-bold';
                                            label = 'Your answer ✗';
                                        } else if (isActualCorrect) {
                                            optClass = 'border-emerald-200 bg-emerald-50 text-emerald-700 border-dashed';
                                            label = 'Correct answer';
                                        }
                                    %>
                                    <div class="flex items-center justify-between p-3 rounded-lg border text-sm <%= optClass %>">
                                        <span><%= opt %></span>
                                        <% if (label) { %><span class="text-xs font-bold"><%= label %></span><% } %>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="mt-8">
            <a href="/student/quizzes" class="w-full inline-block text-center bg-slate-900 text-white font-bold py-4 rounded-xl hover:bg-slate-800 transition-all">
                Back to Quizzes
            </a>
        </div>
    </main>
</body>
</html>
