<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Quiz Result | QuizMaster</title>
        <link href="/css/output.css" rel="stylesheet" />
        <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    </head>
    <body
        class="bg-slate-50 text-slate-900 min-h-screen flex items-center justify-center p-6"
        x-data="{}"
        x-init="confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 }, colors: ['#6366f1', '#a855f7', '#ec4899'] })"
    >
        <div
            class="max-w-2xl w-full bg-white rounded-[3rem] shadow-2xl p-12 border border-slate-100 text-center relative overflow-hidden"
        >
            <div
                class="absolute top-0 left-0 w-full h-2 bg-linear-to-r from-indigo-500 via-purple-500 to-pink-500"
            ></div>

            <div class="mb-10">
                <div
                    class="w-32 h-32 bg-indigo-50 rounded-full flex items-center justify-center mx-auto mb-6"
                >
                    <span class="text-6xl">🏆</span>
                </div>
                <h1 class="text-4xl font-black text-slate-900 tracking-tight">
                    Quiz Completed!
                </h1>
                <p class="text-slate-500 mt-3 text-lg">
                    Well done,
                    <span class="font-bold text-indigo-600"
                        ><%= submission.student.name %></span
                    >! You've finished the test.
                </p>
            </div>

            <div
                class="bg-slate-50 rounded-3xl p-10 mb-10 border border-slate-200/50"
            >
                <div class="grid grid-cols-2 gap-8">
                    <div>
                        <p
                            class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1"
                        >
                            Your Score
                        </p>
                        <p class="text-5xl font-black text-indigo-600">
                            <%= submission.score %>
                        </p>
                    </div>
                    <div>
                        <p
                            class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1"
                        >
                            Total Marks
                        </p>
                        <p class="text-5xl font-black text-slate-300">
                            <%= submission.quiz.totalMarks %>
                        </p>
                    </div>
                </div>

                <div class="mt-10 pt-8 border-t border-slate-200/50">
                    <div
                        class="flex justify-between items-center text-sm font-bold text-slate-500"
                    >
                        <span>Performance</span>
                        <span
                            ><%= Math.round((submission.score /
                            submission.quiz.totalMarks) * 100) %>%</span
                        >
                    </div>
                    <div
                        class="w-full bg-slate-200 h-4 rounded-full mt-3 overflow-hidden"
                    >
                        <div
                            class="bg-indigo-500 h-full rounded-full shadow-[0_0_15px_rgba(99,102,241,0.4)]"
                            style="
                                width: <%=
                                    (
                                        submission.score /
                                            submission.quiz.totalMarks
                                    ) *
                                    100 %>%;
                            "
                        ></div>
                    </div>
                </div>
            </div>

            <p class="text-sm text-slate-400 font-medium mb-10 italic">
                Your results have also been saved in our system.
            </p>

            <div class="flex flex-col space-y-4">
                <% if (submission.student && submission.student.parentPhone) { %>
                <a
                    href="https://wa.me/<%= submission.student.parentPhone.replace(/\D/g, '') %>?text=<%= encodeURIComponent(`Hi! ${submission.student.name} just completed the ${submission.quiz.title} quiz with a score of ${submission.score} out of ${submission.quiz.totalMarks}.`) %>"
                    target="_blank"
                    class="w-full bg-[#25D366] text-white font-bold py-5 rounded-2xl hover:bg-[#1ebd5a] transition-all shadow-lg flex items-center justify-center space-x-3"
                >
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.148.198 2.095 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                    <span>Share Result (Parent WhatsApp)</span>
                </a>
                <% } %>

                <button
                    onclick="window.close()"
                    class="w-full bg-slate-900 text-white font-bold py-5 rounded-2xl hover:bg-slate-800 transition-all shadow-lg flex items-center justify-center"
                >
                    Close Window
                </button>
            </div>
        </div>
    </body>
</html>
