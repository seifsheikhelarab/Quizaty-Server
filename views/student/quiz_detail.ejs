<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 font-sans selection:bg-indigo-100 selection:text-indigo-900">

    <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <a href="/student/quizzes" class="flex items-center space-x-3">
                    <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    <h1 class="text-xl font-black tracking-tight text-slate-900">Back to Quizzes</h1>
                </a>
            </div>
            <a href="/auth/logout" class="text-sm font-bold text-slate-500 hover:text-rose-600 transition-colors">Logout</a>
        </div>
    </header>

    <main class="max-w-2xl mx-auto px-6 py-12">
        <% 
            const now = new Date();
            const isOpen = now >= new Date(quiz.startTime) && now <= new Date(quiz.endTime);
            const isEnded = now > new Date(quiz.endTime);
            const hasSubmitted = submission && submission.submittedAt;
        %>
        <div class="bg-white rounded-2xl border border-slate-200 p-8 shadow-sm">
            <h2 class="text-2xl font-black text-slate-900 mb-2"><%= quiz.title %></h2>
            <% if (quiz.description) { %>
                <p class="text-slate-500 mb-4"><%= quiz.description %></p>
            <% } %>
            <div class="text-sm text-slate-500 space-y-1 mb-6">
                <p>Start: <%= new Date(quiz.startTime).toLocaleString() %></p>
                <p>End: <%= new Date(quiz.endTime).toLocaleString() %></p>
                <p>Duration: <%= quiz.duration %> mins</p>
                <p>Teacher: <%= quiz.teacher.name || 'Teacher' %></p>
            </div>
            <div class="flex flex-wrap gap-3">
                <% if (isOpen && !hasSubmitted) { %>
                    <a href="/quiz/<%= student.id %>/<%= quiz.id %>" class="inline-flex items-center justify-center px-6 py-3 bg-indigo-600 text-white font-bold rounded-lg hover:bg-indigo-700 transition-colors">
                        Attempt Quiz
                    </a>
                <% } %>
                <% if (isEnded && hasSubmitted) { %>
                    <a href="/quiz/<%= student.id %>/<%= quiz.id %>/result" class="inline-flex items-center justify-center px-6 py-3 border border-slate-300 text-slate-700 font-bold rounded-lg hover:bg-slate-50 transition-colors">
                        View Submission
                    </a>
                <% } %>
            </div>
        </div>
    </main>
</body>
</html>
