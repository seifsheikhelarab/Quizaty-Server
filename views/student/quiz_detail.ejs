<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 selection:bg-indigo-100 selection:text-indigo-900">

    <%- include('../partials/student_nav', { backUrl: '/student/quizzes', backText: 'العودة للاختبارات' }) %>

    <main class="max-w-2xl mx-auto px-6 py-12">
        <% 
            const now = new Date();
            const isOpen = now >= new Date(quiz.startTime) && now <= new Date(quiz.endTime);
            const isEnded = now > new Date(quiz.endTime);
            const hasSubmitted = submission && submission.submittedAt;
        %>
        <div class="bg-white rounded-2xl border border-slate-200 p-8 shadow-sm text-right">
            <h2 class="text-2xl font-black text-slate-900 mb-2 border-b pb-4"><%= quiz.title %></h2>
            <% if (quiz.description) { %>
                <p class="text-slate-500 mb-6 py-4 bg-slate-50 px-4 rounded-xl border border-slate-100"><%= quiz.description %></p>
            <% } %>
            <div class="text-sm text-slate-600 space-y-3 mb-8">
                <div class="flex items-center space-x-2 space-x-reverse">
                    <span class="font-bold">البداية:</span>
                    <span><%= new Date(quiz.startTime).toLocaleString('ar-EG') %></span>
                </div>
                <div class="flex items-center space-x-2 space-x-reverse">
                    <span class="font-bold">النهاية:</span>
                    <span><%= new Date(quiz.endTime).toLocaleString('ar-EG') %></span>
                </div>
                <div class="flex items-center space-x-2 space-x-reverse">
                    <span class="font-bold">المدة:</span>
                    <span><%= quiz.duration %> دقيقة</span>
                </div>
                <div class="flex items-center space-x-2 space-x-reverse">
                    <span class="font-bold">المعلم:</span>
                    <span><%= quiz.teacher.name || 'موجه' %></span>
                </div>
            </div>
            <div class="flex flex-wrap gap-3">
                <% if (isOpen && !hasSubmitted) { %>
                    <a href="/quiz/<%= student.id %>/<%= quiz.id %>" class="inline-flex items-center justify-center px-6 py-3 bg-indigo-600 text-white font-bold rounded-xl hover:bg-indigo-700 transition-colors shadow-lg shadow-indigo-200">
                        بدء الاختبار
                    </a>
                <% } %>
                <% if (hasSubmitted && quiz.showResults) { %>
                    <a href="/quiz/<%= student.id %>/<%= quiz.id %>/result" class="inline-flex items-center justify-center px-6 py-3 border border-slate-300 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-colors">
                        عرض النتيجة
                    </a>
                <% } else if (hasSubmitted) { %>
                    <div class="inline-flex items-center justify-center px-6 py-3 bg-amber-50 text-amber-700 font-bold rounded-xl border border-amber-200">
                        تم التسليم - بانتظار النتائج
                    </div>
                <% } %>
            </div>
        </div>
    </main>
</body>
</html>
