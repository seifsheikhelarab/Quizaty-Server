<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-900 selection:bg-indigo-100 selection:text-indigo-900">

    <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3 space-x-reverse">
                <a href="/student/quizzes" class="flex items-center space-x-3 space-x-reverse group">
                    <svg class="w-5 h-5 text-slate-500 group-hover:text-indigo-600 transition-colors rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    <h1 class="text-xl font-black tracking-tight text-slate-900 group-hover:text-indigo-600 transition-colors">العودة للاختبارات</h1>
                </a>
            </div>
            <div class="flex items-center">
                <a href="/auth/logout" class="text-sm font-bold text-slate-500 hover:text-rose-600 transition-colors flex items-center group">
                    <span>تسجيل الخروج</span>
                    <svg class="w-4 h-4 mr-1.5 opacity-50 group-hover:opacity-100 transition-opacity rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                </a>
            </div>
        </div>
    </header>

    <main class="max-w-2xl mx-auto px-6 py-12">
        <% 
            const now = new Date();
            const isOpen = now >= new Date(quiz.startTime) && now <= new Date(quiz.endTime);
            const isEnded = now > new Date(quiz.endTime);
            const hasSubmitted = submission && submission.submittedAt;
        %>
        <div class="bg-white rounded-3xl border border-slate-200 p-10 shadow-xl relative overflow-hidden text-right">
            <div class="absolute top-0 right-0 w-2 h-full bg-indigo-500"></div>
            
            <div class="mb-8">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-black tracking-wide uppercase bg-indigo-50 text-indigo-700 mb-4 shadow-sm border border-indigo-100">تفاصيل الاختبار</span>
                <h2 class="text-3xl font-black text-slate-900 mb-3 leading-tight"><%= quiz.title %></h2>
                <% if (quiz.description) { %>
                    <p class="text-slate-500 text-lg leading-relaxed"><%= quiz.description %></p>
                <% } %>
            </div>

            <div class="bg-slate-50 rounded-2xl p-6 space-y-4 mb-8 border border-slate-100">
                <div class="flex items-center justify-between">
                    <span class="text-sm font-bold text-slate-500">وقت البدء:</span>
                    <span class="text-sm font-black text-slate-900" dir="ltr"><%= new Date(quiz.startTime).toLocaleString('ar-EG') %></span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-sm font-bold text-slate-500">وقت الانتهاء:</span>
                    <span class="text-sm font-black text-slate-900" dir="ltr"><%= new Date(quiz.endTime).toLocaleString('ar-EG') %></span>
                </div>
                <div class="h-px bg-slate-200 w-full"></div>
                <div class="flex items-center justify-between">
                    <span class="text-sm font-bold text-slate-500">المدة الزمنية:</span>
                    <span class="text-sm font-black text-indigo-600"><%= quiz.duration %> دقيقة</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-sm font-bold text-slate-500">المعلم:</span>
                    <span class="text-sm font-black text-slate-900"><%= quiz.teacher.name || 'المعلم' %></span>
                </div>
            </div>

            <div class="flex flex-col gap-4">
                <% if (isOpen && !hasSubmitted) { %>
                    <a href="/quiz/<%= student.id %>/<%= quiz.id %>" class="w-full inline-flex items-center justify-center px-8 py-4 bg-indigo-600 text-white font-black rounded-xl hover:bg-indigo-700 transition-all shadow-lg hover:shadow-indigo-500/30 text-lg">
                        بدء محاولة الاختبار
                        <svg class="w-5 h-5 mr-2 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </a>
                <% } else if (hasSubmitted) { %>
                    <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 flex items-center justify-between mb-4">
                        <div class="flex items-center">
                            <div class="w-10 h-10 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-600 ml-3">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-emerald-900">تم الإرسال</h4>
                                <p class="text-xs text-emerald-600 font-medium">لقد أتممت هذا الاختبار بالفعل.</p>
                            </div>
                        </div>
                        <% if (isEnded) { %>
                            <a href="/quiz/<%= student.id %>/<%= quiz.id %>/result" class="px-4 py-2 bg-white border border-emerald-200 text-emerald-700 text-sm font-black rounded-lg hover:bg-emerald-50 transition-colors shadow-sm">
                                عرض النتيجة
                            </a>
                        <% } %>
                    </div>
                <% } %>
                
                <a href="/student/quizzes" class="w-full inline-flex items-center justify-center px-8 py-4 border-2 border-slate-200 text-slate-600 font-black rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all">
                    العودة للقائمة
                </a>
            </div>
        </div>
    </main>
</body>
</html>
