<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-900 selection:bg-indigo-100 selection:text-indigo-900">

<header class="bg-white border-b border-slate-200 sticky top-0 z-40">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="flex items-center space-x-3 space-x-reverse">
            <a href="/student/dashboard" class="flex items-center space-x-3 space-x-reverse">
                <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center transform -rotate-3">
                    <svg class="w-5 h-5 text-white rotate-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
                </div>
                <h1 class="text-xl font-black tracking-tight text-slate-900">كويز ماستر</h1>
            </a>
            <span class="px-2.5 py-1 bg-indigo-50 text-indigo-700 text-xs font-bold rounded-md border border-indigo-100">طالب</span>
        </div>
        <div class="flex items-center space-x-6 space-x-reverse">
            <a href="/student/dashboard" class="text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors flex items-center">
                <svg class="w-4 h-4 ml-1 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                لوحة التحكم
            </a>
            <a href="/auth/logout" class="text-sm font-bold text-slate-500 hover:text-rose-600 transition-colors flex items-center group">
                <span>تسجيل الخروج</span>
                <svg class="w-4 h-4 mr-1.5 opacity-50 group-hover:opacity-100 transition-opacity rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
            </a>
        </div>
    </div>
</header>

<main class="max-w-6xl mx-auto px-6 py-12">
    <div class="mb-10 text-right">
        <h2 class="text-3xl font-black text-slate-900 tracking-tight">الاختبارات المتاحة</h2>
        <p class="text-slate-500 mt-2 text-lg">جميع الاختبارات الموكلة لك في فصولك الدراسية.</p>
    </div>

    <% if (quizzes.length === 0) { %>
        <div class="bg-white rounded-3xl border border-slate-200 p-16 text-center shadow-sm">
            <div class="w-20 h-20 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-6 transform rotate-3">
                <span class="text-4xl -rotate-3">📝</span>
            </div>
            <h3 class="text-xl font-black text-slate-900 mb-3">لا توجد اختبارات</h3>
            <p class="text-slate-500 font-medium">لم يتم تعيين أي اختبارات لفصولك الدراسية بعد. تابع هذه الصفحة باستمرار.</p>
        </div>
    <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% quizzes.forEach(quiz => { %>
                <% 
                    const now = new Date();
                    const startDate = new Date(quiz.startTime);
                    const endDate = new Date(quiz.endTime);
                    const isOpen = now >= startDate && now <= endDate;
                    const isEnded = now > endDate;
                    const isUpcoming = now < startDate;
                    
                    let statusText = isUpcoming ? 'قادم' : (isOpen ? 'مفتوح' : 'منتهي');
                    let statusColor = isUpcoming ? 'bg-amber-100 text-amber-800' : (isOpen ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-100 text-slate-800');
                    
                    const sub = submissionMap[quiz.id];
                    const hasSubmitted = sub && sub.submittedAt;
                    const scoreReleased = isEnded;
                %>
                <div class="bg-white rounded-3xl border border-slate-200 p-8 flex flex-col hover:shadow-xl hover:border-indigo-300 transition-all duration-300 text-right group relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-1.5 h-full bg-indigo-500 transform scale-y-0 group-hover:scale-y-100 transition-transform origin-top"></div>
                    <div>
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-black tracking-wide uppercase <%= statusColor %> mb-4 shadow-sm"><%= statusText %></span>
                    </div>
                    <h3 class="text-2xl font-black text-slate-900 mb-2 leading-tight group-hover:text-indigo-600 transition-colors"><%= quiz.title %></h3>
                    <% if (quiz.description) { %>
                        <p class="text-sm text-slate-500 mb-4 line-clamp-2 leading-relaxed"><%= quiz.description %></p>
                    <% } %>
                    <div class="text-xs font-bold text-slate-400 mb-4 flex items-center bg-slate-50 p-2 rounded-lg">
                        <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <span dir="ltr"><%= startDate.toLocaleDateString('ar-EG') %></span>
                        <span class="mx-1 font-normal">-</span>
                        <span dir="ltr"><%= endDate.toLocaleDateString('ar-EG') %></span>
                    </div>
                    <p class="text-sm font-bold text-indigo-600 mb-6 flex items-center">
                        <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        <%= quiz.teacher.name || 'المعلم' %>
                    </p>
                    
                    <div class="flex flex-wrap gap-3 mt-auto pt-6 border-t border-slate-100 justify-start">
                        <a href="/student/quizzes/<%= quiz.id %>" class="inline-flex items-center justify-center px-4 py-2.5 border border-slate-200 text-sm font-black rounded-xl text-slate-700 bg-white hover:bg-slate-50 hover:border-slate-300 transition-all shadow-sm">
                            التفاصيل
                        </a>
                        <% if (scoreReleased && hasSubmitted) { %>
                            <a href="/quiz/<%= student.id %>/<%= quiz.id %>/result" class="inline-flex items-center justify-center px-4 py-2.5 border border-transparent text-sm font-black rounded-xl text-white bg-indigo-600 hover:bg-indigo-700 transition-all shadow-lg hover:shadow-indigo-500/30">
                                النتيجة
                            </a>
                        <% } %>
                        <% if (isOpen && !hasSubmitted) { %>
                            <a href="/quiz/<%= student.id %>/<%= quiz.id %>" class="inline-flex items-center justify-center px-4 py-2.5 border border-transparent text-sm font-black rounded-xl text-white bg-emerald-600 hover:bg-emerald-700 transition-all shadow-lg hover:shadow-emerald-500/30">
                                بدء الاختبار
                            </a>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</main>
</body>
</html>
