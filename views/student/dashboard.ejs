<!DOCTYPE html>
<html lang="ar" dir="rtl">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>
        <link href="/css/output.css" rel="stylesheet" />
        <link
            href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap"
            rel="stylesheet"
        />
        <style>
            body {
                font-family: "Cairo", sans-serif;
            }
        </style>
    </head>
    <body
        class="bg-slate-50 min-h-screen text-slate-900 selection:bg-indigo-100 selection:text-indigo-900"
    >
        <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
            <div
                class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between"
            >
                <div class="flex items-center space-x-3 space-x-reverse">
                    <div
                        class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center transform -rotate-3"
                    >
                        <svg
                            class="w-5 h-5 text-white rotate-3"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 14l9-5-9-5-9 5 9 5z"
                            ></path>
                        </svg>
                    </div>
                    <h1
                        class="text-xl font-black tracking-tight text-slate-900"
                    >
                        كويز ماستر
                    </h1>
                    <span
                        class="px-2.5 py-1 bg-indigo-50 text-indigo-700 text-xs font-bold rounded-md border border-indigo-100"
                        >طالب</span
                    >
                </div>

                <div class="flex items-center space-x-6 space-x-reverse">
                    <div class="flex items-center space-x-3 space-x-reverse">
                        <div
                            class="w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center text-slate-600 font-bold border border-slate-200"
                        >
                            <%= student.name ?
                            student.name.charAt(0).toUpperCase() : 'ط' %>
                        </div>
                        <span
                            class="font-bold text-sm text-slate-700 hidden sm:block"
                            ><%= student.name || 'طالب' %></span
                        >
                    </div>
                    <div class="h-6 w-px bg-slate-200"></div>
                    <a
                        href="/auth/logout"
                        class="text-sm font-bold text-slate-500 hover:text-rose-600 transition-colors flex items-center group"
                    >
                        <span>تسجيل الخروج</span>
                        <svg
                            class="w-4 h-4 mr-1.5 opacity-50 group-hover:opacity-100 transition-opacity rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>
        </header>

        <main class="max-w-6xl mx-auto px-6 py-12">
            <div class="mb-12 text-right">
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">
                    مرحباً، <%= student.name || 'طالب' %>! 👋
                </h2>
                <p class="text-slate-500 mt-2 text-lg">
                    اختر وجهتك المفضلة وتابع تقدمك.
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                <!-- Upcoming Quizzes Card -->
                <a
                    href="/student/quizzes"
                    class="block bg-white p-8 rounded-3xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-indigo-300 transition-all duration-300 group relative overflow-hidden"
                >
                    <div
                        class="absolute top-0 right-0 w-2 h-full bg-indigo-500"
                    ></div>
                    <div class="flex items-center justify-between mb-6">
                        <div
                            class="w-14 h-14 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600 group-hover:scale-110 transition-transform shadow-sm"
                        >
                            <svg
                                class="w-7 h-7"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"
                                ></path>
                            </svg>
                        </div>
                        <svg
                            class="w-6 h-6 text-slate-300 group-hover:text-indigo-400 transition-colors rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5l7 7-7 7"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-5xl font-black text-slate-900">
                            <%= stats.upcomingQuizzes %>
                        </h3>
                        <p class="text-lg font-bold text-slate-500 mt-2">
                            الاختبارات القادمة
                        </p>
                        <p class="text-sm text-slate-400 mt-1">
                            اختبارات تنتظر وقت البدء أو مفتوحة حالياً.
                        </p>
                    </div>
                </a>

                <!-- Classes Card -->
                <a
                    href="/student/classes"
                    class="block bg-white p-8 rounded-3xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-emerald-300 transition-all duration-300 group relative overflow-hidden"
                >
                    <div
                        class="absolute top-0 right-0 w-2 h-full bg-emerald-500"
                    ></div>
                    <div class="flex items-center justify-between mb-6">
                        <div
                            class="w-14 h-14 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600 group-hover:scale-110 transition-transform shadow-sm"
                        >
                            <svg
                                class="w-7 h-7"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                                ></path>
                            </svg>
                        </div>
                        <svg
                            class="w-6 h-6 text-slate-300 group-hover:text-emerald-400 transition-colors rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5l7 7-7 7"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-5xl font-black text-slate-900">
                            <%= stats.classes %>
                        </h3>
                        <p class="text-lg font-bold text-slate-500 mt-2">
                            الفصول الدراسية
                        </p>
                        <p class="text-sm text-slate-400 mt-1">
                            الفصول التي أنت مسجل فيها مع معلميك.
                        </p>
                    </div>
                </a>
            </div>
        </main>
    </body>
</html>
