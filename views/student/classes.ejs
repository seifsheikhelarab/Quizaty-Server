<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 selection:bg-indigo-100 selection:text-indigo-900">

    <%- include('../partials/student_nav', { active: 'classes' }) %>

    <main class="max-w-6xl mx-auto px-6 py-12">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 pb-6 border-b border-slate-200">
            <div class="text-right">
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">فصولي الدراسية</h2>
                <p class="text-slate-500 mt-2 text-lg">الفصول التي التحقت بها.</p>
            </div>
            <div class="mt-4 md:mt-0">
                <div class="relative">
                    <svg class="w-5 h-5 absolute right-3 top-1/2 transform -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    <input type="text" id="searchInput" placeholder="ابحث عن فصل..." class="pr-10 pl-4 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 w-64 text-right">
                </div>
            </div>
        </div>

        <% if (classes.length === 0) { %>
            <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center">
                <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                </div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">لا توجد فصول بعد</h3>
                <p class="text-slate-500 max-w-sm mx-auto">أنت لست ملتحقاً بأي فصول حالياً. تواصل مع معلمك لإضافتك.</p>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="classesGrid">
                <% classes.forEach(c => { %>
                    <div class="bg-white rounded-2xl border border-slate-200 p-6 hover:shadow-md hover:border-indigo-300 transition-all class-card text-right">
                        <h3 class="text-xl font-bold text-slate-900 class-name mb-2"><%= c.name %></h3>
                        <p class="text-sm text-slate-500 mb-1"><%= c._count.students %> طالب</p>
                        <p class="text-sm font-medium text-indigo-600 teacher-name"><%= c.teacher.name || 'معلم' %></p>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <script>
        document.getElementById('searchInput')?.addEventListener('input', function(e) {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.class-card').forEach(card => {
                const name = card.querySelector('.class-name')?.textContent?.toLowerCase() || '';
                const teacher = card.querySelector('.teacher-name')?.textContent?.toLowerCase() || '';
                card.style.display = (name.includes(term) || teacher.includes(term)) ? 'block' : 'none';
            });
        });
    </script>
</body>
</html>
