<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6 text-slate-900 selection:bg-indigo-100 selection:text-indigo-900">

    <div class="max-w-md w-full bg-white rounded-4xl shadow-xl border border-slate-100 p-10 relative overflow-hidden">
        <!-- Accent Line -->
        <div class="absolute top-0 right-0 w-full h-1.5 bg-indigo-500"></div>

        <div class="text-center mb-10">
            <div class="w-16 h-16 bg-linear-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-6 transform rotate-3 shadow-lg shadow-indigo-200">
                <svg class="w-8 h-8 text-white -rotate-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path></svg>
            </div>
            <h2 class="text-3xl font-black tracking-tight text-slate-900">إنشاء حساب</h2>
            <p class="text-slate-500 mt-2 font-medium text-sm">ابدأ في إدارة اختباراتك اليوم بسهولة واحترافية.</p>
        </div>

        <form class="space-y-6 text-right" action="/auth/signup" method="POST">
            <% if (error) { %>
                <div class="bg-rose-50 border border-rose-200 text-rose-600 px-5 py-4 rounded-xl mb-6 flex items-start text-right">
                    <svg class="w-5 h-5 ml-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span class="font-medium text-sm"><%= error %></span>
                </div>
            <% } %>

            <div class="space-y-4">
                <div>
                    <label for="name" class="block text-sm font-bold text-slate-700 mb-2">الاسم الكامل</label>
                    <input id="name" name="name" type="text" required class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 focus:bg-white transition-all outline-none font-medium placeholder:text-slate-400 text-right" placeholder="أدخل اسمك الكامل">
                </div>
                <div>
                    <label for="email-address" class="block text-sm font-bold text-slate-700 mb-2">البريد الإلكتروني</label>
                    <input id="email-address" name="email" type="email" autocomplete="email" required class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 focus:bg-white transition-all outline-none font-medium placeholder:text-slate-400 text-right" placeholder="example@mail.com">
                </div>
                <div>
                    <label for="password" class="block text-sm font-bold text-slate-700 mb-2">كلمة المرور</label>
                    <input id="password" name="password" type="password" autocomplete="new-password" required class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 focus:bg-white transition-all outline-none font-medium placeholder:text-slate-400 text-right" placeholder="••••••••">
                </div>
            </div>

            <div>
                <button type="submit" class="w-full bg-indigo-600 text-white font-bold py-4 px-6 rounded-xl hover:bg-indigo-700 focus:ring-4 focus:ring-indigo-500/50 transition-all shadow-lg hover:shadow-indigo-500/30 outline-none flex items-center justify-center space-x-2 space-x-reverse">
                    <span>إنشاء الحساب</span>
                    <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </button>
            </div>
        </form>

        <div class="mt-8 pt-8 border-t border-slate-100 text-center">
            <a href="/auth/login" class="text-sm font-bold text-indigo-600 hover:text-indigo-700 hover:underline underline-offset-4">
                لديك حساب بالفعل؟ تسجيل الدخول
            </a>
        </div>
    </div>
</body>
</html>
