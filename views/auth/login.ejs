<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6 text-slate-900 selection:bg-indigo-100 selection:text-indigo-900">

    <div class="max-w-md mx-auto w-full bg-white rounded-4xl shadow-xl border border-slate-100 p-10 relative overflow-hidden">
        <!-- Accent Line -->
        <div class="absolute top-0 right-0 w-full h-1.5 bg-indigo-500"></div>

        <div class="text-center mb-10">
            <div class="w-16 h-16 bg-indigo-50 rounded-2xl flex items-center justify-center mx-auto mb-6 transform rotate-3">
                <svg class="w-8 h-8 text-indigo-600 -rotate-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path></svg>
            </div>
            <h1 class="text-3xl font-black tracking-tight text-slate-900">تسجيل الدخول</h1>
            <p class="text-slate-500 mt-2 font-medium">مرحباً بك! يرجى اختيار دورك والمتابعة.</p>
        </div>

        <% if (error) { %>
            <div class="bg-rose-50 border border-rose-200 text-rose-600 px-5 py-4 rounded-xl mb-8 flex items-start text-right">
                <svg class="w-5 h-5 ml-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span class="font-medium text-sm"><%= error %></span>
            </div>
        <% } %>

        <!-- Role Selector -->
        <div class="flex justify-center mb-8 bg-slate-100 p-1 rounded-2xl">
            <button type="button" id="btn-student" class="w-1/2 py-2.5 text-sm font-black rounded-xl bg-white shadow-sm text-indigo-600 transition-all duration-200" onclick="setRole('student')">
                طالب
            </button>
            <button type="button" id="btn-teacher" class="w-1/2 py-2.5 text-sm font-bold rounded-xl text-slate-500 hover:text-slate-900 transition-all duration-200" onclick="setRole('teacher')">
                معلم
            </button>
        </div>

        <form action="/auth/login" method="POST" id="loginForm" class="space-y-6 text-right">
            <input type="hidden" name="role" id="roleInput" value="student">

            <div id="phone-field">
                <label class="block text-sm font-bold text-slate-700 mb-2" for="phone">رقم الهاتف</label>
                <input class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 focus:bg-white transition-all outline-none font-medium placeholder:text-slate-400 text-right" 
                       id="phone" 
                       type="tel" 
                       name="phone" 
                       placeholder="01xxxxxxxxx"
                       required>
            </div>

            <div id="email-field" class="hidden">
                <label class="block text-sm font-bold text-slate-700 mb-2" for="email">البريد الإلكتروني</label>
                <input class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 focus:bg-white transition-all outline-none font-medium placeholder:text-slate-400 text-right" 
                       id="email" 
                       type="email" 
                       name="email" 
                       placeholder="example@mail.com">
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2" for="password">كلمة المرور</label>
                <input class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 focus:bg-white transition-all outline-none font-medium placeholder:text-slate-400 text-right" 
                       id="password" 
                       type="password" 
                       name="password" 
                       placeholder="••••••••"
                       required>
            </div>

            <button class="w-full bg-indigo-600 text-white font-bold py-4 px-6 rounded-xl hover:bg-indigo-700 focus:ring-4 focus:ring-indigo-500/50 transition-all shadow-lg hover:shadow-indigo-500/30 outline-none flex items-center justify-center space-x-2 space-x-reverse" 
                    type="submit">
                <span>تسجيل الدخول</span>
                <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </button>
        </form>

        <div class="mt-8 pt-8 border-t border-slate-100 text-center">
            <p class="text-sm text-slate-500 font-medium">
                ليس لديك حساب؟
                <a href="/auth/register" class="text-indigo-600 hover:text-indigo-700 font-bold hover:underline underline-offset-4 mr-1">أنشئ حساباً جديداً</a>
            </p>
        </div>
    </div>

    <script>
        function setRole(role) {
            const btnStudent = document.getElementById('btn-student');
            const btnTeacher = document.getElementById('btn-teacher');
            const roleInput = document.getElementById('roleInput');
            const phoneField = document.getElementById('phone-field');
            const phoneInput = document.getElementById('phone');
            const emailField = document.getElementById('email-field');
            const emailInput = document.getElementById('email');
            
            roleInput.value = role;

            if (role === 'student') {
                btnStudent.className = "w-1/2 py-2.5 text-sm font-black rounded-xl bg-white shadow-sm text-indigo-600 transition-all duration-200";
                btnTeacher.className = "w-1/2 py-2.5 text-sm font-bold rounded-xl text-slate-500 hover:text-slate-900 transition-all duration-200";
                emailField.classList.add('hidden');
                emailInput.removeAttribute('required');
                phoneField.classList.remove('hidden');
                phoneInput.setAttribute('required', 'required');
            } else {
                btnTeacher.className = "w-1/2 py-2.5 text-sm font-black rounded-xl bg-white shadow-sm text-indigo-600 transition-all duration-200";
                btnStudent.className = "w-1/2 py-2.5 text-sm font-bold rounded-xl text-slate-500 hover:text-slate-900 transition-all duration-200";
                phoneField.classList.add('hidden');
                phoneInput.removeAttribute('required');
                emailField.classList.remove('hidden');
                emailInput.setAttribute('required', 'required');
            }
        }
    </script>
</body>
</html>
