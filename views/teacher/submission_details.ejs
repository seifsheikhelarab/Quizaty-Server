<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>body { font-family: "Inter", sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 font-sans selection:bg-indigo-100 selection:text-indigo-900">

    <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <a href="/teacher/dashboard" class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center transform -rotate-3">
                        <svg class="w-5 h-5 text-white rotate-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
                    </div>
                    <h1 class="text-xl font-black tracking-tight text-slate-900">QuizMaster</h1>
                </a>
            </div>
            
            <div class="flex items-center space-x-6">
                <a href="/teacher/quizzes/<%= quiz.id %>" class="text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Back to Quiz
                </a>
            </div>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">
        <div class="mb-8">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 mb-3">
                <%= quiz.title %>
            </span>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Submission: <%= submission.student.name %></h2>
            
            <% 
                const timeTakenMins = submission.submittedAt ? ((new Date(submission.submittedAt).getTime() - new Date(submission.startedAt).getTime()) / 60000).toFixed(1) : 'N/A';
                const scoreColor = submission.score >= (quiz.totalMarks / 2) ? 'text-emerald-600' : 'text-rose-600';
                
                let answers = {};
                if (submission.answers) {
                    answers = typeof submission.answers === 'string' ? JSON.parse(submission.answers) : submission.answers;
                }
                let violationsRaw = submission.violations;
                if (typeof violationsRaw === 'string') {
                    try { violationsRaw = JSON.parse(violationsRaw); } catch(e) {}
                }
                const violationsList = Array.isArray(violationsRaw) ? violationsRaw : (violationsRaw && typeof violationsRaw === 'object' ? Object.entries(violationsRaw).map(([k,v]) => ({ type: k, details: v })) : []);
                const hasViolations = violationsList.length > 0;
            %>
            
            <div class="mt-4 flex flex-wrap gap-4 text-sm text-slate-500 font-medium">
                <div class="flex items-center bg-white px-3 py-1.5 rounded-lg border border-slate-200 shadow-sm">
                    <span class="text-xs uppercase text-slate-400 mr-2">Score</span>
                    <span class="text-lg font-black <%= scoreColor %>"><%= submission.score %></span><span class="text-slate-400">/<%= quiz.totalMarks %></span>
                </div>
                <div class="flex items-center bg-white px-3 py-1.5 rounded-lg border border-slate-200 shadow-sm">
                    <span class="text-xs uppercase text-slate-400 mr-2">Time</span>
                    <span class="text-slate-900 font-bold"><%= timeTakenMins %> mins</span>
                </div>
                <div class="flex items-center bg-white px-3 py-1.5 rounded-lg border border-slate-200 shadow-sm">
                    <span class="text-xs uppercase text-slate-400 mr-2">Submitted On</span>
                    <span class="text-slate-900"><%= new Date(submission.submittedAt || submission.startedAt).toLocaleString() %></span>
                </div>
            </div>
        </div>

        <% if (hasViolations) { %>
            <div class="bg-amber-50 border-l-4 border-amber-500 rounded-lg p-5 mb-8 flex items-start shadow-sm">
                <svg class="w-6 h-6 text-amber-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                <div>
                    <h3 class="text-amber-800 font-bold mb-1">Violations Detected</h3>
                    <p class="text-amber-700 text-sm mb-3">This student triggered cheating prevention checks during the quiz.</p>
                    <ul class="list-disc list-inside text-sm text-amber-800 font-medium space-y-1">
                        <% violationsList.forEach(v => { %>
                            <li><%= v.type %>: <%= typeof v.details === 'object' ? JSON.stringify(v.details) : v.details %></li>
                        <% }) %>
                    </ul>
                </div>
            </div>
        <% } %>

        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-100 bg-slate-50">
                <h3 class="font-bold text-slate-900">Detailed Answers</h3>
            </div>
            
            <div class="p-6 space-y-8">
                <% quiz.questions.forEach((q, index) => { %>
                    <% 
                        const studentAnswerStr = answers[q.id];
                        const studentAnswer = studentAnswerStr !== undefined ? parseInt(studentAnswerStr) : -1;
                        const isCorrect = studentAnswer === q.correctOption;
                        
                        let badgeColor = '';
                        let badgeText = '';
                        let badgeIcon = '';
                        
                        if (studentAnswer === -1) {
                            badgeColor = 'bg-slate-100 text-slate-600 border border-slate-200';
                            badgeText = 'Skipped';
                            badgeIcon = `<svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 12H6"></path></svg>`;
                        } else if (isCorrect) {
                            badgeColor = 'bg-emerald-100 text-emerald-800 border border-emerald-200';
                            badgeText = 'Correct';
                            badgeIcon = `<svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>`;
                        } else {
                            badgeColor = 'bg-rose-100 text-rose-800 border border-rose-200';
                            badgeText = 'Incorrect';
                            badgeIcon = `<svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>`;
                        }
                    %>
                    <div class="border border-slate-100 rounded-xl p-5 bg-white shadow-sm relative overflow-hidden">
                        <% if(isCorrect) { %>
                            <div class="absolute top-0 left-0 w-1 h-full bg-emerald-500"></div>
                        <% } else if (studentAnswer !== -1) { %>
                            <div class="absolute top-0 left-0 w-1 h-full bg-rose-500"></div>
                        <% } else { %>
                            <div class="absolute top-0 left-0 w-1 h-full bg-slate-300"></div>
                        <% } %>
                        
                        <div class="pl-3">
                            <div class="flex justify-between items-start mb-4">
                                <h4 class="text-sm font-bold text-slate-900 leading-snug pr-4">
                                    <span class="text-slate-400 mr-1"><%= index + 1 %>.</span> <%= q.questionText %>
                                </h4>
                                <span class="inline-flex items-center px-2 py-1 rounded text-xs font-bold shrink-0 <%= badgeColor %>">
                                    <%- badgeIcon %> <%= badgeText %>
                                </span>
                            </div>

                            <% if(q.imageUrl) { %>
                                <div class="mb-4">
                                    <img src="<%= q.imageUrl %>" alt="Question illustration" class="max-h-48 rounded border border-slate-200">
                                </div>
                            <% } %>

                            <div class="space-y-2 mt-4">
                                <% q.options.forEach((opt, optIndex) => { %>
                                    <% 
                                        const isSelected = studentAnswer === optIndex;
                                        const isActualCorrect = q.correctOption === optIndex;
                                        
                                        let optClass = 'border-slate-200 text-slate-600 bg-white';
                                        let icon = '';
                                        
                                        if (isSelected && isActualCorrect) {
                                            optClass = 'border-emerald-500 bg-emerald-50 text-emerald-900 font-bold ring-1 ring-emerald-500';
                                            icon = `<svg class="w-5 h-5 text-emerald-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>`;
                                        } else if (isSelected && !isActualCorrect) {
                                            optClass = 'border-rose-300 bg-rose-50 text-rose-900 font-bold';
                                            icon = `<svg class="w-5 h-5 text-rose-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>`;
                                        } else if (!isSelected && isActualCorrect) {
                                            optClass = 'border-emerald-200 bg-emerald-50 text-emerald-700 border-dashed';
                                            icon = `<span class="text-xs font-bold text-emerald-600 uppercase tracking-widest bg-emerald-100 px-2 py-0.5 rounded">Correct Answer</span>`;
                                        } else {
                                            // Empty circle for unselected options
                                            icon = `<div class="w-4 h-4 rounded-full border border-slate-300 ml-0.5"></div>`;
                                        }
                                    %>
                                    <div class="flex items-center justify-between p-3 rounded-lg border text-sm <%= optClass %> transition-colors">
                                        <span class="pl-2"><%= opt %></span>
                                        <div class="pr-2 text-right flex items-center shrink-0">
                                            <%- icon %>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
            
        </div>
    </main>

</body>
</html>
