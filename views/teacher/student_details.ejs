<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Cairo', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 selection:bg-indigo-100 selection:text-indigo-900">

    <!-- Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3 space-x-reverse">
                <a href="/teacher/dashboard" class="flex items-center space-x-3 space-x-reverse">
                    <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center transform -rotate-3">
                        <svg class="w-5 h-5 text-white rotate-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
                    </div>
                    <h1 class="text-xl font-black tracking-tight text-slate-900">QuizMaster</h1>
                </a>
            </div>
            
            <div class="flex items-center space-x-6 space-x-reverse">
                <a href="/teacher/classes" class="text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors flex items-center">
                    <svg class="w-4 h-4 ml-1 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    العودة للفصول
                </a>
            </div>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">
        <div class="mb-10 text-right">
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">تفاصيل الطالب</h2>
            <p class="text-slate-500 mt-2 text-lg">عرض ملف الطالب والأداء الأكاديمي.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-right">
            <!-- Student Profile Info -->
            <div class="md:col-span-1 space-y-6">
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
                    <div class="text-center mb-6">
                        <div class="w-20 h-20 bg-indigo-100 rounded-full flex items-center justify-center mx-auto mb-4 border-2 border-white shadow-sm">
                            <span class="text-2xl font-black text-indigo-600"><%= student.name.charAt(0).toUpperCase() %></span>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900"><%= student.name %></h3>
                        <p class="text-slate-500 text-sm mt-1">طالب</p>
                    </div>

                    <div class="space-y-4 pt-6 border-t border-slate-100">
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">البريد الإلكتروني</p>
                            <p class="text-sm font-medium text-slate-700 truncate"><%= student.email %></p>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">الهاتف</p>
                            <p class="text-sm font-medium text-slate-700"><%= student.phone || 'غير متوفر' %></p>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">هاتف ولي الأمر</p>
                            <p class="text-sm font-medium text-slate-700"><%= student.parentPhone || 'غير متوفر' %></p>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">الفصل الدراسي</p>
                            <p class="text-sm font-medium text-indigo-600">
                                <% if(student.class) { %>
                                    <a href="/teacher/classes/<%= student.class.id %>" class="hover:underline"><%= student.class.name %></a>
                                <% } else { %>
                                    غير محدد
                                <% } %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quiz Attempts -->
            <div class="md:col-span-2 space-y-6">
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden text-right">
                    <div class="px-6 py-5 border-b border-slate-100 bg-slate-50">
                        <h3 class="text-lg font-bold text-slate-900">محاولات الاختبارات</h3>
                    </div>
                    
                    <% if (student.submissions && student.submissions.length > 0) { %>
                        <div class="overflow-x-auto">
                            <table class="w-full text-right">
                                <thead>
                                    <tr class="bg-slate-50 border-b border-slate-100">
                                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">الاختبار</th>
                                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">التاريخ</th>
                                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">الدرجة</th>
                                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">المخالفات</th>
                                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest"></th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100">
                                    <% student.submissions.forEach(sub => { %>
                                        <tr class="hover:bg-slate-50/50 transition-colors">
                                            <td class="px-6 py-4">
                                                <p class="font-bold text-slate-900"><%= sub.quiz.title %></p>
                                                <p class="text-xs text-slate-500 mt-0.5 max-w-[200px] truncate"><%= sub.quiz.description || '' %></p>
                                            </td>
                                            <td class="px-6 py-4 text-center text-sm text-slate-600">
                                                <%= new Date(sub.submittedAt).toLocaleDateString('ar-EG') %>
                                            </td>
                                            <td class="px-6 py-4 text-center">
                                                <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-sm font-black <%= sub.score >= (sub.quiz.totalMarks / 2) ? 'bg-emerald-50 text-emerald-600' : 'bg-rose-50 text-rose-600' %>">
                                                    <%= sub.score %> / <%= sub.quiz.totalMarks %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 text-center">
                                                <% 
                                                    let hasViolations = false;
                                                    if (sub.violations) {
                                                        const v = typeof sub.violations === 'string' ? JSON.parse(sub.violations) : sub.violations;
                                                        hasViolations = Array.isArray(v) ? v.length > 0 : (v && Object.keys(v).length > 0);
                                                    }
                                                %>
                                                <% if(hasViolations) { %>
                                                    <span class="inline-flex items-center px-2 py-1 rounded text-[10px] font-bold bg-amber-100 text-amber-800 uppercase tracking-widest">
                                                        نعم
                                                    </span>
                                                <% } else { %>
                                                    <span class="text-xs text-slate-400 font-medium">لا يوجد</span>
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4 text-left">
                                                <a href="/teacher/quizzes/<%= sub.quiz.id %>/submissions/<%= sub.id %>" class="text-indigo-600 hover:text-indigo-900 text-sm font-bold">التفاصيل</a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="p-12 text-center">
                            <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4">
                                <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                            </div>
                            <p class="text-slate-500 text-sm font-medium">لم يقم هذا الطالب بتسليم أي اختبارات بعد.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

</body>
</html>
