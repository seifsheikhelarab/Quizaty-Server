<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>body { font-family: "Inter", sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 font-sans selection:bg-indigo-100 selection:text-indigo-900">

    <!-- Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <a href="/teacher/dashboard" class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center transform -rotate-3">
                        <svg class="w-5 h-5 text-white rotate-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
                    </div>
                    <h1 class="text-xl font-black tracking-tight text-slate-900">QuizMaster</h1>
                </a>
            </div>
            
            <div class="flex items-center space-x-6">
                <!-- If returning to class details -->
                <% if(student.classId) { %>
                <a href="/teacher/classes/<%= student.classId %>" class="text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Back to Class
                </a>
                <% } else { %>
                <a href="/teacher/dashboard" class="text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Back to Dashboard
                </a>
                <% } %>
            </div>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-12">
        <div class="mb-10">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 mb-2">
                Student
            </span>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight"><%= student.name %></h2>
            <div class="mt-2 text-slate-500 flex items-center space-x-4">
                <span class="flex items-center"><svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg> <%= student.phone %></span>
                <% if(student.class) { %>
                    <span class="flex items-center"><svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg> <%= student.class.name %></span>
                <% } %>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
            <!-- Score Analysis -->
            <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
                <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-6">Score Analysis</h3>
                <div class="grid grid-cols-3 gap-4">
                    <div class="text-center">
                        <p class="text-3xl font-black text-emerald-600"><%= analysis.bestScore %></p>
                        <p class="text-xs font-medium text-slate-500 mt-1">Best</p>
                    </div>
                    <div class="text-center border-l border-r border-slate-100">
                        <p class="text-3xl font-black text-slate-900"><%= analysis.avgScore %></p>
                        <p class="text-xs font-medium text-slate-500 mt-1">Average</p>
                    </div>
                    <div class="text-center">
                        <p class="text-3xl font-black text-rose-600"><%= analysis.worstScore %></p>
                        <p class="text-xs font-medium text-slate-500 mt-1">Worst</p>
                    </div>
                </div>
            </div>

            <!-- Time Analysis -->
            <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
                <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-6">Time Analysis</h3>
                <div class="grid grid-cols-3 gap-4">
                    <div class="text-center">
                        <p class="text-3xl font-black text-emerald-600"><%= analysis.bestTime %></p>
                        <p class="text-xs font-medium text-slate-500 mt-1">Fastest</p>
                    </div>
                    <div class="text-center border-l border-r border-slate-100">
                        <p class="text-3xl font-black text-slate-900"><%= analysis.avgTime %></p>
                        <p class="text-xs font-medium text-slate-500 mt-1">Average</p>
                    </div>
                    <div class="text-center">
                        <p class="text-3xl font-black text-rose-600"><%= analysis.worstTime %></p>
                        <p class="text-xs font-medium text-slate-500 mt-1">Slowest</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- History -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-100 bg-slate-50">
                <h3 class="text-lg font-bold text-slate-900">Quiz Attempts (<%= student.submissions.length %>)</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-white border-b border-slate-100 text-xs font-bold text-slate-400 uppercase tracking-wider">
                            <th class="p-4 pl-6">Quiz Name</th>
                            <th class="p-4">Date</th>
                            <th class="p-4">Time Taken</th>
                            <th class="p-4">Score</th>
                            <th class="p-4 pr-6 text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% if (student.submissions.length === 0) { %>
                            <tr>
                                <td colspan="5" class="p-8 text-center text-slate-500 text-sm">No quiz attempts yet.</td>
                            </tr>
                        <% } else { %>
                            <% student.submissions.forEach(sub => { %>
                                <% 
                                    let timeTaken = 'N/A';
                                    if(sub.submittedAt && sub.startedAt) {
                                        const mins = (new Date(sub.submittedAt).getTime() - new Date(sub.startedAt).getTime()) / 60000;
                                        timeTaken = Math.round(mins) + ' mins';
                                    }
                                    const scoreColor = sub.score >= (sub.quiz.totalMarks / 2) ? 'text-emerald-600' : 'text-rose-600';
                                %>
                                <tr class="hover:bg-slate-50 transition-colors group">
                                    <td class="p-4 pl-6 font-bold text-slate-900 text-sm"><%= sub.quiz.title %></td>
                                    <td class="p-4 text-slate-500 text-sm"><%= new Date(sub.startedAt).toLocaleDateString() %></td>
                                    <td class="p-4 text-slate-500 text-sm"><%= timeTaken %> <!-- / <%= sub.quiz.duration %>m --></td>
                                    <td class="p-4 font-black <%= scoreColor %> text-sm">
                                        <% if(sub.submittedAt) { %>
                                            <%= sub.score %> / <%= sub.quiz.totalMarks %>
                                        <% } else { %>
                                            <span class="text-amber-500 font-bold">In Progress</span>
                                        <% } %>
                                    </td>
                                    <td class="p-4 pr-6 text-right">
                                        <% if(sub.submittedAt) { %>
                                            <!-- Next feature to implement: Detailed submission view -->
                                            <a href="/teacher/quizzes/<%= sub.quiz.id %>/submissions/<%= sub.id %>" class="inline-flex items-center justify-center px-3 py-1.5 border border-slate-300 text-xs font-bold rounded-md text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                                                Details
                                            </a>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

</body>
</html>
