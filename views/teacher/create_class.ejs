<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>
        <link href="/css/output.css" rel="stylesheet" />
        <link
            href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap"
            rel="stylesheet"
        />
        <style>
            body {
                font-family: "Cairo", sans-serif;
            }
        </style>
    </head>
    <body
        class="bg-slate-50 min-h-screen text-slate-800 selection:bg-indigo-100 selection:text-indigo-900"
    >
        <!-- Header -->
        <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
            <div
                class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between"
            >
                <div class="flex items-center space-x-3 space-x-reverse">
                    <a
                        href="/teacher/dashboard"
                        class="flex items-center space-x-3 space-x-reverse"
                    >
                        <div
                            class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center transform -rotate-3"
                        >
                            <svg
                                class="w-5 h-5 text-white rotate-3"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 14l9-5-9-5-9 5 9 5z"
                                ></path>
                            </svg>
                        </div>
                        <h1
                            class="text-xl font-black tracking-tight text-slate-900"
                        >
                            QuizMaster
                        </h1>
                    </a>
                </div>

                <div class="flex items-center space-x-6 space-x-reverse">
                    <a
                        href="/teacher/classes"
                        class="text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors flex items-center"
                    >
                        <svg
                            class="w-4 h-4 ml-1 rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M10 19l-7-7m0 0l7-7m-7 7h18"
                            ></path>
                        </svg>
                        العودة للفصول
                    </a>
                </div>
            </div>
        </header>

        <main class="max-w-xl mx-auto px-6 py-12">
            <div class="mb-8 text-right">
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">
                    إنشاء فصل جديد
                </h2>
                <p class="text-slate-500 mt-2 text-lg">
                    قم بإعداد فصل جديد لتنظيم طلابك.
                </p>
            </div>

            <div
                class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden"
            >
                <form
                    action="/teacher/classes/create"
                    method="POST"
                    class="p-8"
                >
                    <div class="space-y-6">
                        <div class="text-right">
                            <label
                                for="name"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >اسم الفصل</label
                            >
                            <input
                                type="text"
                                name="name"
                                id="name"
                                required
                                class="block w-full border border-slate-300 rounded-lg shadow-sm py-2.5 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right"
                                placeholder="مثال: رياضيات الصف العاشر"
                            />
                        </div>
                        <div class="text-right">
                            <label
                                for="description"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >وصف الفصل
                                <span class="text-slate-400 font-normal"
                                    >(اختياري)</span
                                ></label
                            >
                            <textarea
                                name="description"
                                id="description"
                                rows="3"
                                class="block w-full border border-slate-300 rounded-lg shadow-sm py-2.5 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right"
                                placeholder="وصف قصير للفصل"
                            ></textarea>
                        </div>
                        <div class="text-right">
                            <label
                                for="studentPhones"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >إضافة طلاب
                                <span class="text-slate-400 font-normal"
                                    >(اختياري)</span
                                ></label
                            >
                            <textarea
                                name="studentPhones"
                                id="studentPhones"
                                rows="4"
                                class="block w-full border border-slate-300 rounded-lg shadow-sm py-2.5 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right"
                                placeholder="رقم هاتف واحد في كل سطر (مثال: 0123456789)"
                            ></textarea>
                            <p class="mt-2 text-sm text-slate-500">
                                أدخل أرقام الهواتف، واحد في كل سطر. سيتم إنشاء
                                الطلاب أو ربطهم إذا كانوا موجودين بالفعل.
                            </p>
                        </div>
                    </div>

                    <div
                        class="mt-8 pt-6 border-t border-slate-100 flex items-center justify-end space-x-4 space-x-reverse"
                    >
                        <a
                            href="/teacher/classes"
                            class="inline-flex items-center justify-center px-4 py-2 border border-slate-300 shadow-sm text-sm font-bold rounded-lg text-slate-700 bg-white hover:bg-slate-50 focus:outline-none transition-colors"
                        >
                            إلغاء
                        </a>
                        <button
                            type="submit"
                            class="inline-flex items-center justify-center px-6 py-2 border border-transparent text-sm font-bold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 shadow-sm transition-colors"
                        >
                            إنشاء الفصل
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </body>
</html>
