<!DOCTYPE html>
<html lang="ar" dir="rtl">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>
        <link href="/css/output.css" rel="stylesheet" />
        <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
        <style>
            body {
                font-family: 'Cairo', sans-serif;
            }
        </style>
    </head>
    <body
        class="bg-slate-50 min-h-screen text-slate-800 selection:bg-indigo-100 selection:text-indigo-900"
    >
        <!-- Header -->
        <%- include('../partials/teacher_nav', { backUrl: '/teacher/classes', backText: 'العودة للفصول' }) %>

        <main class="max-w-xl mx-auto px-6 py-12 text-right">
            <div class="mb-8">
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">
                    إنشاء فصل جديد
                </h2>
                <p class="text-slate-500 mt-2 text-lg">
                    قم بإعداد فصل جديد لتنظيم طلابك.
                </p>
                <% if (limits) { %>
                    <div class="mt-4 bg-slate-900 text-slate-50 rounded-2xl px-4 py-3 text-xs flex items-center justify-between flex-row-reverse">
                        <div class="text-right">
                            <p class="font-semibold tracking-wide uppercase text-[11px] text-slate-400">الباقة الحالية</p>
                            <p class="font-bold text-sm mt-0.5">
                                <% 
                                    const tierMap = {
                                        'FREE_TRIAL': 'تجربة مجانية',
                                        'STARTER': 'أساسي',
                                        'PRO': 'احترافي',
                                        'UNLIMITED': 'غير محدود'
                                    };
                                    const tierName = tierMap[subscription ? subscription.tier : 'FREE_TRIAL'] || (subscription ? subscription.tier : 'تجربة مجانية');
                                %>
                                <%= tierName %>
                            </p>
                        </div>
                        <div class="flex gap-6 text-[11px] flex-row-reverse">
                            <% if (limits.maxClasses !== null) { %>
                                <div class="text-center">
                                    <p class="text-slate-400">الفصول</p>
                                    <p class="font-semibold">
                                        <%= usage ? usage.classCount : 0 %> / <%= limits.maxClasses %>
                                    </p>
                                </div>
                            <% } %>
                            <% if (limits.maxStudentsPerClass !== null) { %>
                                <div class="text-center">
                                    <p class="text-slate-400">الطلاب/فصل</p>
                                    <p class="font-semibold"><%= limits.maxStudentsPerClass %> كحد أقصى</p>
                                </div>
                            <% } %>
                            <% if (limits.maxTotalStudents !== null) { %>
                                <div class="text-center">
                                    <p class="text-slate-400">إجمالي الطلاب</p>
                                    <p class="font-semibold">
                                        <%= usage ? usage.totalStudents : 0 %> / <%= limits.maxTotalStudents %>
                                    </p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            </div>

            <div
                class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden"
            >
                <form
                    action="/teacher/classes/create"
                    method="POST"
                    class="p-8"
                >
                    <div class="space-y-6">
                        <div>
                            <label
                                for="name"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >اسم الفصل</label
                            >
                            <input
                                type="text"
                                name="name"
                                id="name"
                                required
                                class="block w-full border border-slate-300 rounded-lg shadow-sm py-2.5 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right"
                                placeholder="مثال: رياضيات الصف العاشر"
                            />
                        </div>
                        <div>
                            <label
                                for="description"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >وصف الفصل <span class="text-slate-400 font-normal mr-1">(اختياري)</span></label
                            >
                            <textarea
                                name="description"
                                id="description"
                                rows="3"
                                class="block w-full border border-slate-300 rounded-lg shadow-sm py-2.5 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right"
                                placeholder="وصف موجز للفصل"
                            ></textarea>
                        </div>
                        <div>
                            <label
                                for="studentPhones"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >إضافة طلاب <span class="text-slate-400 font-normal mr-1">(اختياري)</span></label
                            >
                            <textarea
                                name="studentPhones"
                                id="studentPhones"
                                rows="4"
                                dir="ltr"
                                class="block w-full border border-slate-300 rounded-lg shadow-sm py-2.5 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-left"
                                placeholder="رقم هاتف واحد في كل سطر (مثال: 01234567890)"
                            ></textarea>
                            <p class="mt-2 text-sm text-slate-500">
                                أدخل أرقام الهواتف، واحد في كل سطر. سيتم إنشاء الطلاب أو ربطهم إذا كانوا موجودين بالفعل.
                            </p>
                        </div>
                    </div>

                    <div
                        class="mt-8 pt-6 border-t border-slate-100 flex items-center justify-end space-x-4 space-x-reverse"
                    >
                        <a
                            href="/teacher/classes"
                            class="inline-flex items-center justify-center px-4 py-2 border border-slate-300 shadow-sm text-sm font-bold rounded-lg text-slate-700 bg-white hover:bg-slate-50 focus:outline-none transition-colors"
                        >
                            إلغاء
                        </a>
                        <button
                            type="submit"
                            class="inline-flex items-center justify-center px-6 py-2 border border-transparent text-sm font-bold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 shadow-sm transition-colors"
                        >
                            إنشاء الفصل
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </body>
</html>
