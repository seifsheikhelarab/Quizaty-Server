<!DOCTYPE html>
<html lang="ar" dir="rtl">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>
        <link href="/css/output.css" rel="stylesheet" />
        <link
            href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap"
            rel="stylesheet"
        />
        <style>
            body {
                font-family: "Cairo", sans-serif;
            }
        </style>
    </head>
    <body
        class="bg-slate-50 min-h-screen text-slate-800 selection:bg-indigo-100 selection:text-indigo-900"
    >
        <%- include('../partials/teacher_nav', { backUrl: '/teacher/classes/' + classData.id, backText: 'العودة للفصل' }) %>

        <main class="max-w-xl mx-auto px-6 py-12 text-right">
            <div class="mb-8 text-right">
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">
                    تعديل الفصل: <%= classData.name %>
                </h2>
                <p class="text-slate-500 mt-2 text-lg">
                    قم بتحديث بيانات هذا الفصل.
                </p>
            </div>

            <form
                action="/teacher/classes/<%= classData.id %>/edit"
                method="POST"
                class="space-y-6"
            >
                <div
                    class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8"
                >
                    <div class="space-y-6">
                        <div>
                            <label
                                for="name"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >اسم الفصل</label
                            >
                            <input
                                type="text"
                                name="name"
                                id="name"
                                value="<%= classData.name %>"
                                required
                                class="block w-full border border-slate-300 rounded-lg py-2.5 px-4 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right"
                            />
                        </div>
                        <div>
                            <label
                                for="description"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >وصف الفصل
                                <span class="text-slate-400 font-normal mr-1"
                                    >(اختياري)</span
                                ></label
                            >
                            <textarea
                                name="description"
                                id="description"
                                rows="3"
                                class="block w-full border border-slate-300 rounded-lg py-2.5 px-4 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right"
                            >
<%= classData.description || '' %></textarea
                            >
                        </div>
                    </div>
                </div>

                <div class="flex justify-end space-x-4 space-x-reverse">
                    <a
                        href="/teacher/classes/<%= classData.id %>"
                        class="inline-flex items-center justify-center px-6 py-3 border border-slate-300 shadow-sm text-sm font-bold rounded-lg text-slate-700 bg-white hover:bg-slate-50 focus:outline-none transition-colors"
                    >
                        إلغاء
                    </a>
                    <button
                        type="submit"
                        class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-sm font-bold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none shrink-0 shadow-sm transition-colors"
                    >
                        حفظ التغييرات
                    </button>
                </div>
            </form>
        </main>
    </body>
</html>
