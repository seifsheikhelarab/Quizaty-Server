<nav class="bg-indigo-700 text-white shadow-lg sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
            <div class="flex items-center space-x-3">
                <a href="/teacher/dashboard" class="text-2xl font-bold bg-white/20 p-2 rounded-lg">🎓</a>
                <span class="text-xl font-bold tracking-tight"><a href="/teacher/dashboard">QuizMaster Pro</a></span>
            </div>
            <div class="flex items-center space-x-6">
                <span class="text-sm font-medium opacity-80">Welcome, <%= teacher.name %></span>
                <a href="/auth/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200">Logout</a>
            </div>
        </div>
    </div>
</nav>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6">
        <a href="/teacher/quizzes" class="text-indigo-600 hover:text-indigo-800 flex items-center text-sm font-medium">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Back to Quizzes
        </a>
    </div>

    <div class="mb-10 flex justify-between items-end">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Submissions: <%= quiz.title %></h1>
            <p class="text-slate-500 mt-2">Total score achievable: <%= quiz.totalMarks %></p>
        </div>
        
        <form action="/teacher/quizzes/<%= quiz.id %>/release-results" method="POST" class="inline-block">
            <button type="submit" class="inline-flex items-center px-6 py-3 bg-emerald-600 text-white font-semibold rounded-xl hover:bg-emerald-700 transition-all duration-200 shadow-md">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                Release Results via Telegram
            </button>
        </form>
    </div>

    <div class="bg-white shadow rounded-lg overflow-hidden border border-slate-200">
        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50 border-b border-slate-200">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Student</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Group</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Phone / Telegram</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Submitted At</th>
                    <th class="px-6 py-4 text-center text-xs font-semibold text-slate-500 uppercase tracking-wider">Score</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-slate-200">
                <% submissions.forEach(sub => { %>
                <tr class="hover:bg-slate-50 transition-colors duration-150">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center">
                            <div class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold">
                                <%= sub.student.name.charAt(0).toUpperCase() %>
                            </div>
                            <div class="ml-4">
                                <div class="text-sm font-medium text-slate-900"><%= sub.student.name %></div>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm text-slate-500 border border-slate-200 rounded-full px-3 py-1 bg-slate-50 inline-block"><%= sub.student.groupName %></div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm text-slate-900"><%= sub.student.phone %></div>
                        <div class="text-xs <%= sub.student.telegramId ? 'text-emerald-500' : 'text-slate-400' %> uppercase tracking-wide font-medium mt-1">
                            <%= sub.student.telegramId ? 'Telegram Linked' : 'No Telegram' %>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                        <% if(sub.submittedAt) { %>
                            <%= new Date(sub.submittedAt).toLocaleString() %>
                        <% } else { %>
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                In Progress
                            </span>
                        <% } %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-center">
                        <% if(sub.submittedAt) { %>
                            <span class="px-3 py-1 inline-flex text-sm leading-5 font-bold rounded-full bg-slate-100 text-slate-800">
                                <%= sub.score %> / <%= quiz.totalMarks %>
                            </span>
                        <% } else { %>
                            <span class="text-slate-400 font-bold">-</span>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
                <% if(submissions.length === 0) { %>
                <tr>
                    <td colspan="5" class="px-6 py-12 text-center text-slate-500">
                        <div class="flex flex-col items-center justify-center">
                            <svg class="w-12 h-12 text-slate-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                            <p class="text-lg font-medium text-slate-900">No submissions yet.</p>
                            <p class="text-sm">Students haven't submitted this quiz.</p>
                        </div>
                    </td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</main>
