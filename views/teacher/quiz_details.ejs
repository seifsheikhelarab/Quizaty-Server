<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Cairo', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 selection:bg-indigo-100 selection:text-indigo-900">

    <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3 space-x-reverse">
                <a href="/teacher/dashboard" class="flex items-center space-x-3 space-x-reverse">
                    <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center transform -rotate-3">
                        <svg class="w-5 h-5 text-white rotate-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
                    </div>
                    <h1 class="text-xl font-black tracking-tight text-slate-900">QuizMaster</h1>
                </a>
            </div>
            
            <div class="flex items-center space-x-6 space-x-reverse">
                <a href="/teacher/quizzes" class="text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors flex items-center">
                    <svg class="w-4 h-4 ml-1 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    العودة للاختبارات
                </a>
            </div>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-12">
        <% 
            const now = new Date();
            const isUpcoming = now < quiz.startTime;
            const isEnded = now > quiz.endTime;
            const isActive = !isUpcoming && !isEnded;
            
            let statusText = '';
            let statusColor = '';
            if (isUpcoming) {
                statusText = 'قادم';
                statusColor = 'bg-amber-100 text-amber-800';
            } else if (isEnded) {
                statusText = 'منتهي';
                statusColor = 'bg-slate-100 text-slate-800';
            } else {
                statusText = 'مفتوح';
                statusColor = 'bg-emerald-100 text-emerald-800';
            }
        %>

        <div class="flex flex-col md:flex-row-reverse md:items-start justify-between mb-8 pb-6 border-b border-slate-200 text-right">
            <div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold <%= statusColor %> mb-3">
                    <%= statusText %>
                </span>
                <h2 class="text-3xl font-black text-slate-900 tracking-tight"><%= quiz.title %></h2>
                <% if(quiz.description) { %>
                    <p class="text-slate-500 mt-2 text-base"><%= quiz.description %></p>
                <% } %>
                <div class="mt-4 flex items-center md:justify-end space-x-6 space-x-reverse text-sm text-slate-500">
                    <div class="flex items-center">
                        <svg class="w-4 h-4 ml-1.5 min-w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <%= new Date(quiz.startTime).toLocaleDateString('ar-EG') %> - <%= new Date(quiz.endTime).toLocaleDateString('ar-EG') %>
                    </div>
                    <div class="flex items-center">
                        <svg class="w-4 h-4 ml-1.5 min-w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <%= quiz.duration %> دقيقة
                    </div>
                    <div class="flex items-center">
                        <svg class="w-4 h-4 ml-1.5 min-w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
                        <%= quiz.totalMarks %> درجة
                    </div>
                </div>
            </div>
            <div class="mt-6 md:mt-0 flex flex-wrap items-center gap-3 md:justify-start">
                <% if(isUpcoming) { %>
                    <a href="/teacher/quizzes/<%= quiz.id %>/edit" class="inline-flex items-center justify-center px-4 py-2 border border-slate-300 text-sm font-bold rounded-lg text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                        تعديل الاختبار
                    </a>
                    <form action="/teacher/quizzes/<%= quiz.id %>/delete" method="POST" onsubmit="return confirm('هل أنت متأكد من حذف هذا الاختبار نهائياً؟');" class="inline">
                        <button type="submit" class="inline-flex items-center justify-center px-4 py-2 border border-slate-300 text-sm font-bold rounded-lg text-rose-600 bg-white hover:bg-rose-50 transition-colors">
                            حذف الاختبار
                        </button>
                    </form>
                <% } %>
                
                <% if(isEnded) { %>
                    <form action="/teacher/quizzes/<%= quiz.id %>/release-results" method="POST">
                        <button type="submit" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-bold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm transition-colors">
                            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                            نشر النتائج
                        </button>
                    </form>
                <% } %>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- Main Content: Analysis & Submissions -->
            <div class="lg:col-span-2 space-y-8 order-2 lg:order-1">
                
                <!-- Submissions Analysis -->
                <% if (submissions.length > 0) { %>
                    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden text-right">
                        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50">
                            <h3 class="text-lg font-bold text-slate-900">تحليل التسليمات</h3>
                        </div>
                        <div class="p-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <!-- Score Stats -->
                                <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
                                    <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-6">تحليل الدرجات</h3>
                                    <div class="grid grid-cols-3 gap-4">
                                        <div class="text-center">
                                            <p class="text-3xl font-black text-emerald-600"><%= analysis.bestScore %></p>
                                            <p class="text-xs font-medium text-slate-500 mt-1">الأعلى</p>
                                        </div>
                                        <div class="text-center border-l border-r border-slate-100">
                                            <p class="text-3xl font-black text-slate-900"><%= analysis.avgScore %></p>
                                            <p class="text-xs font-medium text-slate-500 mt-1">المتوسط</p>
                                        </div>
                                        <div class="text-center">
                                            <p class="text-3xl font-black text-rose-600"><%= analysis.worstScore %></p>
                                            <p class="text-xs font-medium text-slate-500 mt-1">الأدنى</p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Participation & Time -->
                                <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
                                    <div class="flex items-center justify-between mb-6 flex-row-reverse">
                                        <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider">إحصائيات الاختبار</h3>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-indigo-100 text-indigo-800">
                                            المشاركة: <%= analysis.participation %>
                                        </span>
                                    </div>
                                    <div class="grid grid-cols-3 gap-4">
                                        <div class="text-center">
                                            <p class="text-3xl font-black text-emerald-600"><%= analysis.bestTime %></p>
                                            <p class="text-xs font-medium text-slate-500 mt-1">الأسرع</p>
                                        </div>
                                        <div class="text-center border-l border-r border-slate-100">
                                            <p class="text-3xl font-black text-slate-900"><%= analysis.avgTime %></p>
                                            <p class="text-xs font-medium text-slate-500 mt-1">المتوسط</p>
                                        </div>
                                        <div class="text-center">
                                            <p class="text-3xl font-black text-rose-600"><%= analysis.worstTime %></p>
                                            <p class="text-xs font-medium text-slate-500 mt-1">الأبطأ</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="bg-blue-50 bg-opacity-50 rounded-2xl border border-blue-100 p-6 text-center">
                        <p class="text-sm text-blue-700 font-medium tracking-wide">سيظهر التحليل هنا بمجرد قيام الطلاب بتسليم الاختبار.</p>
                    </div>
                <% } %>

                <!-- Submissions Cards -->
                <div class="space-y-4 text-right" id="submissions">
                    <h3 class="text-lg font-bold text-slate-900 mb-4 px-1">التسليمات (<%= submissions.length %>)</h3>
                    
                    <% if (submissions.length === 0) { %>
                        <div class="bg-white rounded-xl border border-slate-200 p-8 text-center text-slate-500 text-sm shadow-sm">
                            لم يتم استلام أي تسليمات بعد.
                        </div>
                    <% } else { %>
                        <% submissions.forEach((sub, index) => { %>
                            <% 
                                const scoreColor = sub.score >= (quiz.totalMarks / 2) ? 'text-emerald-600' : 'text-rose-600';
                                const timeTakenMins = ((sub.submittedAt.getTime() - sub.startedAt.getTime()) / 60000).toFixed(1);
                                
                                let hasViolations = false;
                                if (sub.violations) {
                                    const v = typeof sub.violations === 'string' ? JSON.parse(sub.violations) : sub.violations;
                                    hasViolations = Array.isArray(v) ? v.length > 0 : (v && Object.keys(v).length > 0);
                                }
                            %>
                            <div class="bg-white rounded-xl border <%= hasViolations ? 'border-amber-300 shadow-amber-50' : 'border-slate-200 shadow-sm' %> p-5 flex flex-col md:flex-row-reverse md:items-center justify-between gap-4 transition-all hover:shadow-md">
                                <div class="flex items-center space-x-4 space-x-reverse text-right">
                                    <div class="w-10 h-10 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center text-slate-600 font-bold shrink-0">
                                        <%= sub.student.name.charAt(0).toUpperCase() %>
                                    </div>
                                    <div class="grow">
                                        <h4 class="font-bold text-slate-900 group">
                                            <a href="/teacher/students/<%= sub.student.id %>" class="hover:text-indigo-600 transition-colors"><%= sub.student.name %></a>
                                            <% if(hasViolations) { %>
                                                <span class="inline-flex items-center px-2 py-1 rounded text-[10px] font-black uppercase tracking-widest bg-emerald-100 text-emerald-800 ml-4 flex-row-reverse">
                                                    تم اكتشاف مخالفات
                                                </span>
                                            <% } %>
                                        </h4>
                                        <p class="text-xs text-slate-500 mt-0.5">تم التسليم <%= new Date(sub.submittedAt).toLocaleTimeString('ar-EG', {hour: '2-digit', minute:'2-digit'}) %></p>
                                    </div>
                                </div>
                                
                                <div class="flex items-center space-x-6 space-x-reverse">
                                    <div class="text-center">
                                        <p class="text-xl font-black <%= scoreColor %>"><%= sub.score %><span class="text-sm font-bold text-slate-400">/<%= quiz.totalMarks %></span></p>
                                        <p class="text-[10px] uppercase font-bold text-slate-400 mt-0.5">الدرجة</p>
                                    </div>
                                    <div class="text-center w-16">
                                        <p class="text-lg font-bold text-slate-700"><%= timeTakenMins %>د</p>
                                        <p class="text-[10px] uppercase font-bold text-slate-400 mt-0.5">الوقت</p>
                                    </div>
                                    <div class="flex items-center space-x-2 space-x-reverse">
                                        <% 
                                            const waPhone = (sub.student.parentPhone || sub.student.phone).replace(/[^0-9]/g, '');
                                            const appBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : '';
                                            const waMessage = encodeURIComponent(`نتائج الاختبار: ${quiz.title}\nالدرجة: ${sub.score}/${quiz.totalMarks}\nعرض التفاصيل: ${appBaseUrl}/quiz/${sub.student.id}/${quiz.id}/result`);
                                        %>
                                        <a href="https://wa.me/<%= waPhone %>?text=<%= waMessage %>" target="_blank" class="w-9 h-9 flex items-center justify-center rounded-lg bg-[#25D366] text-white hover:bg-[#128C7E] transition-colors" title="إرسال النتائج عبر واتساب">
                                            <svg class="w-5 h-5 block" viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                                            </svg>
                                        </a>
                                        <a href="/teacher/quizzes/<%= quiz.id %>/submissions/<%= sub.id %>" class="inline-flex items-center justify-center px-4 py-2 border border-slate-300 text-xs font-bold rounded-lg text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                                            التفاصيل
                                        </a>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>

            <!-- Sidebar: Leaderboard & Questions -->
            <div class="space-y-8 order-1 lg:order-2">
                
                <!-- Leaderboard -->
                <% if(leaderboard.length > 0) { %>
                <div class="bg-indigo-600 rounded-2xl shadow-lg overflow-hidden text-white relative text-right">
                    <!-- decorative dots -->
                    <div class="absolute top-0 left-0 -ml-8 -mt-8 opacity-20">
                        <svg width="100" height="100" viewBox="0 0 100 100" fill="currentColor">
                            <circle cx="20" cy="20" r="4"/>
                            <circle cx="50" cy="20" r="4"/>
                            <circle cx="80" cy="20" r="4"/>
                            <circle cx="20" cy="50" r="4"/>
                            <circle cx="50" cy="50" r="4"/>
                            <circle cx="80" cy="50" r="4"/>
                            <circle cx="20" cy="80" r="4"/>
                            <circle cx="50" cy="80" r="4"/>
                            <circle cx="80" cy="80" r="4"/>
                        </svg>
                    </div>

                    <div class="px-6 py-5 border-b border-indigo-700/50 relative z-10 flex items-center justify-end">
                        <h3 class="flex items-center text-lg font-black text-white">
                            لوحة الصدارة
                            <svg class="w-5 h-5 text-yellow-400 ml-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2l2.35 4.77 5.26.77-3.81 3.7.9 5.24L10 14.01l-4.7 2.47.9-5.24-3.81-3.7 5.26-.77L10 2z" clip-rule="evenodd"></path></svg>
                        </h3>
                    </div>
                    <div class="p-6 relative z-10 space-y-4">
                        <% leaderboard.forEach((sub, index) => { %>
                            <% 
                                const medals = ['text-yellow-400', 'text-slate-300', 'text-amber-700'];
                                const bgMedals = ['bg-indigo-700/60', 'bg-indigo-700/40', 'bg-indigo-700/20'];
                                const classMedal = medals[index] || 'text-white/50';
                                const bgMedal = bgMedals[index] || 'bg-transparent';
                            %>
                            <div class="flex items-center p-3 rounded-xl <%= bgMedal %> backdrop-blur-sm border border-indigo-500/30 flex-row-reverse">
                                <div class="font-black text-xl <%= classMedal %> w-6 text-center shrink-0">
                                    <%= index + 1 %>
                                </div>
                                <div class="mr-3 flex-grow text-right">
                                    <p class="font-bold text-sm"><%= sub.student.name %></p>
                                    <p class="text-[10px] text-indigo-200 mt-0.5"><%= ((sub.submittedAt.getTime() - sub.startedAt.getTime()) / 60000).toFixed(1) %>د</p>
                                </div>
                                <div class="text-left shrink-0">
                                    <p class="font-black text-lg"><%= sub.score %><span class="text-indigo-300 text-xs">/<%= quiz.totalMarks %></span></p>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
                <% } %>

                <!-- Questions List -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden text-right">
                    <div class="px-6 py-5 border-b border-slate-100 bg-slate-50 flex justify-between items-center flex-row-reverse">
                        <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest">الأسئلة (<%= quiz.questions.length %>)</h3>
                    </div>
                    <div class="overflow-y-auto max-h-96">
                        <% if (quiz.questions.length === 0) { %>
                            <div class="p-6 text-center text-slate-500 text-sm">لم يتم إضافة أسئلة لهذا الاختبار.</div>
                        <% } else { %>
                            <ul class="divide-y divide-slate-100">
                                <% quiz.questions.forEach((q, i) => { %>
                                    <li class="p-4 hover:bg-slate-50 transition-colors">
                                        <div class="flex items-start flex-row-reverse">
                                            <span class="w-6 h-6 rounded bg-slate-100 text-slate-500 text-xs font-bold flex items-center justify-center ml-3 mt-0.5 shrink-0"><%= i + 1 %></span>
                                            <div class="grow">
                                                <p class="text-sm font-bold text-slate-900 mb-2 leading-snug"><%= q.questionText %></p>
                                                <% if(q.imageUrl) { %>
                                                    <a href="<%= q.imageUrl %>" target="_blank" class="inline-flex items-center px-2 py-1 bg-slate-100 text-xs text-slate-600 rounded font-medium mb-3 hover:bg-slate-200 transition-colors flex-row-reverse">
                                                        <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                                        عرض الصورة
                                                    </a>
                                                <% } %>
                                                <div class="grid grid-cols-1 gap-1">
                                                    <% q.options.forEach((opt, optIndex) => { %>
                                                        <div class="text-xs px-2.5 py-1.5 rounded-md flex items-center justify-between flex-row-reverse <%= optIndex === q.correctOption ? 'bg-emerald-50 text-emerald-800 border border-emerald-200 font-bold' : 'bg-white text-slate-600 border border-slate-200' %>">
                                                            <span><%= opt %></span>
                                                            <% if(optIndex === q.correctOption) { %>
                                                                <svg class="w-3 h-3 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                                            <% } %>
                                                        </div>
                                                    <% }) %>
                                                </div>
                                            </div>
                                        </div>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } %>
                    </div>
                </div>

            </div>
        </div>
    </main>

</body>
</html>
