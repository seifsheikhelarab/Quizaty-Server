<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Cairo', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 selection:bg-indigo-100 selection:text-indigo-900">

    <%- include('../partials/teacher_nav', { active: 'quizzes' }) %>

    <main class="max-w-6xl mx-auto px-6 py-12 text-right">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 pb-6 border-b border-slate-200">
            <div>
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">إدارة الاختبارات</h2>
                <p class="text-slate-500 mt-2 text-lg">قم بإنشاء اختبارات جديدة ومراجعة الاختبارات الحالية.</p>
            </div>
            <div class="mt-6 md:mt-0 flex items-center">
                <a href="/teacher/quizzes/create" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-sm font-black rounded-xl text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none shadow-lg shadow-indigo-100 transition-all transform hover:-translate-y-0.5">
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    إنشاء اختبار
                </a>
            </div>
        </div>

        <% if (quizzes.length === 0) { %>
            <div class="bg-white rounded-3xl border border-slate-200 p-12 text-center">
                <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">لا توجد اختبارات متاحة</h3>
                <p class="text-slate-500 max-w-sm mx-auto mb-6">قم بإنشاء أول اختبار لك لبدء تقييم طلابك.</p>
                <a href="/teacher/quizzes/create" class="inline-flex items-center justify-center px-5 py-2.5 border border-transparent text-sm font-bold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none shadow-sm transition-colors">
                    إنشاء اختبار الآن
                </a>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% quizzes.forEach(quiz => { %>
                    <% 
                        const now = new Date();
                        const startDate = new Date(quiz.startTime);
                        const endDate = new Date(quiz.endTime);
                        let statusText = '';
                        let statusColor = '';
                        
                        // Status: open, ended, upcoming (per doc)
                        if (now < startDate) {
                            statusText = 'قادم';
                            statusColor = 'bg-amber-100 text-amber-800';
                        } else if (now > endDate) {
                            statusText = 'منتهي';
                            statusColor = 'bg-slate-100 text-slate-800';
                        } else {
                            statusText = 'مفتوح';
                            statusColor = 'bg-emerald-100 text-emerald-800';
                        }
                    %>
                    <div class="bg-white rounded-3xl border border-slate-200 p-6 flex flex-col hover:shadow-xl hover:border-indigo-300 transition-all duration-300 group">
                        <div class="flex justify-between items-start mb-4 flex-row-reverse">
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-black <%= statusColor %>">
                                <%= statusText %>
                            </span>
                        </div>
                        
                        <h3 class="text-xl font-black text-slate-900 mb-2 group-hover:text-indigo-600 transition-colors"><%= quiz.title %></h3>
                        <% if (quiz.description) { %>
                            <p class="text-sm text-slate-500 mb-4 line-clamp-2"><%= quiz.description %></p>
                        <% } %>
                        
                        <div class="text-sm text-slate-500 mb-6 grow">
                            <div class="flex items-center mt-2 flex-row-reverse">
                                <svg class="w-4 h-4 ml-1.5 min-w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                <span><%= startDate.toLocaleDateString('ar-EG') %> - <%= endDate.toLocaleDateString('ar-EG') %></span>
                            </div>
                        </div>

                        <div class="flex flex-wrap gap-2 flex-row-reverse">
                            <a href="/teacher/quizzes/<%= quiz.id %>" class="inline-flex items-center justify-center px-4 py-2 border border-slate-200 text-xs font-bold rounded-xl text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                                عرض التفاصيل
                            </a>
                            <a href="/teacher/quizzes/<%= quiz.id %>#submissions" class="inline-flex items-center justify-center px-4 py-2 border border-slate-200 text-xs font-bold rounded-xl text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                                عرض التسليمات
                            </a>
                            <% if (now < startDate) { %>
                            <form action="/teacher/quizzes/<%= quiz.id %>/delete" method="POST" onsubmit="return confirm('هل أنت متأكد من حذف هذا الاختبار نهائياً؟');" class="inline">
                                <button type="submit" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-xs font-bold rounded-xl text-rose-700 bg-rose-50 hover:bg-rose-100 transition-colors">
                                    حذف
                                </button>
                            </form>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

</body>
</html>
