<nav class="bg-indigo-700 text-white shadow-lg sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
            <div class="flex items-center space-x-3">
                <span class="text-2xl font-bold bg-white/20 p-2 rounded-lg">🎓</span>
                <span class="text-xl font-bold tracking-tight">QuizMaster Pro</span>
            </div>
            <div class="flex items-center space-x-6">
                <span class="text-sm font-medium opacity-80">Welcome, <%= teacher.name %></span>
                <a href="/auth/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200">Logout</a>
            </div>
        </div>
    </div>
</nav>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-10 flex justify-between items-end">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Teacher Dashboard</h1>
            <p class="text-slate-500 mt-2">Manage your quizzes, students, and track results.</p>
        </div>
        <div class="flex space-x-4">
            <a href="/teacher/students" class="inline-flex items-center px-6 py-3 border border-indigo-600 text-indigo-600 font-semibold rounded-xl hover:bg-indigo-50 transition-all duration-200 shadow-sm">
                Manage Students
            </a>
            <a href="/teacher/quizzes/create" class="inline-flex items-center px-6 py-3 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 transition-all duration-200 shadow-md">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Create New Quiz
            </a>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-slate-500 text-sm font-semibold uppercase tracking-wider">Total Quizzes</p>
                    <p class="text-4xl font-black text-indigo-600 mt-1"><%= quizzes.length %></p>
                </div>
                <div class="bg-indigo-50 p-3 rounded-xl text-indigo-600">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                </div>
            </div>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-slate-500 text-sm font-semibold uppercase tracking-wider">Active Students</p>
                    <p class="text-4xl font-black text-emerald-600 mt-1"><%= studentsCount %></p>
                </div>
                <div class="bg-emerald-50 p-3 rounded-xl text-emerald-600">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                </div>
            </div>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-slate-500 text-sm font-semibold uppercase tracking-wider">Total Submissions</p>
                    <p class="text-4xl font-black text-rose-600 mt-1">
                        <%= quizzes.reduce((acc, q) => acc + q._count.submissions, 0) %>
                    </p>
                </div>
                <div class="bg-rose-50 p-3 rounded-xl text-rose-600">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Quizzes List -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-8 border-b border-slate-100 flex justify-between items-center">
            <h2 class="text-xl font-bold text-slate-900">Recent Quizzes</h2>
            <a href="/teacher/quizzes" class="text-sm font-semibold text-indigo-600 hover:text-indigo-700">View All</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-50 text-slate-500 text-xs font-bold uppercase tracking-wider">
                    <tr>
                        <th class="px-8 py-4">Title</th>
                        <th class="px-8 py-4">Questions</th>
                        <th class="px-8 py-4">Submissions</th>
                        <th class="px-8 py-4">Duration</th>
                        <th class="px-8 py-4">Status</th>
                        <th class="px-8 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <% quizzes.slice(0, 5).forEach(quiz => { %>
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-8 py-6 font-semibold text-slate-900"><%= quiz.title %></td>
                        <td class="px-8 py-6 text-slate-600"><%= quiz._count.questions %></td>
                        <td class="px-8 py-6 text-slate-600"><%= quiz._count.submissions %></td>
                        <td class="px-8 py-6 text-slate-600"><%= quiz.duration %> mins</td>
                        <td class="px-8 py-6">
                            <% const now = new Date(); %>
                            <% if (now < quiz.startTime) { %>
                                <span class="bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full text-xs font-bold">Upcoming</span>
                            <% } else if (now > quiz.endTime) { %>
                                <span class="bg-slate-100 text-slate-800 px-3 py-1 rounded-full text-xs font-bold">Ended</span>
                            <% } else { %>
                                <span class="bg-emerald-100 text-emerald-800 px-3 py-1 rounded-full text-xs font-bold">Active</span>
                            <% } %>
                        </td>
                        <td class="px-8 py-6 text-right">
                            <button class="text-indigo-600 hover:text-indigo-800 font-bold px-4 py-2 hover:bg-indigo-50 rounded-lg transition-all">Edit</button>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (quizzes.length === 0) { %>
                    <tr>
                        <td colspan="6" class="px-8 py-12 text-center text-slate-500">
                            No quizzes created yet. Start by creating one!
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>
