<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Cairo', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 selection:bg-indigo-100 selection:text-indigo-900">

    <%- include('../partials/teacher_nav', { backUrl: '/teacher/quizzes', backText: 'العودة للاختبارات' }) %>

    <main class="max-w-4xl mx-auto px-6 py-12">
        <div class="mb-8 text-right">
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">إنشاء اختبار</h2>
            <p class="text-slate-500 mt-2 text-lg">قم بتحديد إعدادات الاختبار وإضافة أسئلتك.</p>
            <% if (limits) { %>
            <div class="mt-4 bg-slate-900 text-slate-50 rounded-2xl px-4 py-3 text-xs flex items-center justify-between flex-row-reverse">
                <div class="text-right">
                    <p class="font-semibold tracking-wide uppercase text-[11px] text-slate-400">خطة المعلم</p>
                    <p class="font-bold text-sm mt-0.5"><%= subscription ? subscription.tier : 'FREE_TRIAL' %></p>
                </div>
                <div class="flex gap-4 text-[11px] flex-row-reverse">
                    <% if (limits.maxQuizzesPerClassPerMonth !== null) { %>
                        <div class="text-right">
                            <p class="text-slate-400">حد الاختبارات</p>
                            <p class="font-semibold">
                                حتى <%= limits.maxQuizzesPerClassPerMonth %> اختبار لكل فصل في الشهر.
                            </p>
                        </div>
                    <% } else { %>
                        <div class="text-right">
                            <p class="text-slate-400">حد الاختبارات</p>
                            <p class="font-semibold">عدد غير محدود من الاختبارات لكل فصل.</p>
                        </div>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>

        <form action="/teacher/quizzes/create" method="POST" enctype="multipart/form-data" class="space-y-8">
            
            <!-- Quiz Details -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8 text-right">
                <h3 class="text-xl font-bold text-slate-900 mb-6">التفاصيل العامة</h3>
                
                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">عنوان الاختبار</label>
                        <input type="text" name="title" required class="block w-full border border-slate-300 rounded-lg py-2.5 px-4 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right">
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">الوصف <span class="text-slate-400 font-normal">(اختياري)</span></label>
                        <textarea name="description" rows="3" class="block w-full border border-slate-300 rounded-lg py-2.5 px-4 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right"></textarea>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="text-right">
                            <label class="block text-sm font-bold text-slate-700 mb-2">وقت البدء</label>
                            <input type="datetime-local" name="startTime" required class="block w-full border border-slate-300 rounded-lg py-2.5 px-4 bg-white focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right">
                        </div>
                        <div class="text-right">
                            <label class="block text-sm font-bold text-slate-700 mb-2">وقت الانتهاء</label>
                            <input type="datetime-local" name="endTime" required class="block w-full border border-slate-300 rounded-lg py-2.5 px-4 bg-white focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right">
                        </div>
                        <div class="text-right">
                            <label class="block text-sm font-bold text-slate-700 mb-2">المدة (بالدقائق)</label>
                            <input type="number" name="duration" min="1" required class="block w-full border border-slate-300 rounded-lg py-2.5 px-4 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right" placeholder="مثال: 30">
                        </div>
                        <div class="text-right">
                            <label class="block text-sm font-bold text-slate-700 mb-2">إجمالي الدرجات</label>
                            <input type="number" name="totalMarks" min="1" required class="block w-full border border-slate-300 rounded-lg py-2.5 px-4 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right" placeholder="مثال: 100">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-3">تعيين للفصول</label>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                            <% classes.forEach(c => { %>
                                <label class="relative flex items-start p-4 cursor-pointer outline-none rounded-xl border border-slate-200 bg-white hover:bg-slate-50 transition-colors has-checked:border-indigo-600 has-checked:bg-indigo-50 has-checked:ring-1 has-checked:ring-indigo-600 select-none flex-row-reverse">
                                    <div class="flex items-center h-5">
                                        <input type="checkbox" name="classIds[]" value="<%= c.id %>" class="h-4 w-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500">
                                    </div>
                                    <div class="mr-3 text-sm text-right">
                                        <span class="font-bold text-slate-900 block"><%= c.name %></span>
                                    </div>
                                </label>
                            <% }) %>
                            <% if(classes.length === 0) { %>
                                <p class="text-sm text-slate-500 col-span-full">لم يتم العثور على فصول. يمكنك تعيين هذا لاحقاً.</p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Questions -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8 text-right">
                <div class="flex items-center justify-between mb-6 flex-row-reverse">
                    <h3 class="text-xl font-bold text-slate-900">الأسئلة</h3>
                    <button type="button" onclick="addQuestion()" class="inline-flex items-center justify-center px-4 py-2 border border-slate-300 text-sm font-bold rounded-lg text-slate-700 bg-white hover:bg-slate-50 focus:outline-none transition-colors flex-row-reverse">
                        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        إضافة سؤال
                    </button>
                </div>

                <div id="questionsList" class="space-y-6">
                    <!-- Questions injected here via JS -->
                </div>
                
                <div id="noQuestionsFallback" class="hidden text-center py-6 text-slate-500 text-sm">
                    لا توجد أسئلة مضافة. انقر فوق الزر أعلاه لإضافة سؤال.
                </div>
            </div>

            <div class="flex justify-end pt-4 pb-12 space-x-4 space-x-reverse">
                <a href="/teacher/quizzes" class="inline-flex items-center justify-center px-6 py-3 border border-slate-300 shadow-sm text-sm font-bold rounded-lg text-slate-700 bg-white hover:bg-slate-50 focus:outline-none transition-colors">
                    إلغاء
                </a>
                <button type="submit" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-sm font-bold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 shadow-sm transition-colors">
                    حفظ الاختبار
                </button>
            </div>
        </form>
    </main>

    <script>
        let questionCount = 0;
        const questionsList = document.getElementById('questionsList');
        const fallbackMsg = document.getElementById('noQuestionsFallback');

        function toggleFallback() {
            if(questionsList.children.length === 0) {
                fallbackMsg.classList.remove('hidden');
            } else {
                fallbackMsg.classList.add('hidden');
            }
        }

        function addQuestion() {
            const html = `
                <div class="p-6 border border-slate-200 rounded-xl bg-slate-50 relative group transition-colors hover:border-indigo-300 text-right">
                    <div class="absolute top-4 left-4 opacity-0 group-hover:opacity-100 transition-opacity">
                        <button type="button" onclick="this.closest('.relative').remove(); toggleFallback();" class="p-2 text-slate-400 hover:text-rose-600 hover:bg-white rounded-md transition-colors" title="إزالة السؤال">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </button>
                    </div>
                    
                    <div class="mb-5 pl-12">
                        <label class="block text-sm font-bold text-slate-700 mb-2">نص السؤال</label>
                        <input type="text" name="questions[\${questionCount}][text]" required class="block w-full border border-slate-300 rounded-lg py-2.5 px-4 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right">
                    </div>
                    
                    <div class="mb-5">
                        <label class="block text-sm font-bold text-slate-700 mb-2">صورة توضيحية <span class="text-slate-400 font-normal">(اختياري)</span></label>
                        <input type="file" name="questions[\${questionCount}][image]" accept="image/*" class="block w-full text-sm text-slate-500 file:ml-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-bold file:bg-white file:text-slate-700 file:border file:border-slate-300 hover:file:bg-slate-50 transition-colors">
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
                        <div class="relative">
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">الخيار 1</label>
                            <input type="text" name="questions[\${questionCount}][options][]" required class="block w-full border border-slate-300 rounded-lg py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right">
                        </div>
                        <div class="relative">
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">الخيار 2</label>
                            <input type="text" name="questions[\${questionCount}][options][]" required class="block w-full border border-slate-300 rounded-lg py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right">
                        </div>
                        <div class="relative">
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">الخيار 3</label>
                            <input type="text" name="questions[\${questionCount}][options][]" required class="block w-full border border-slate-300 rounded-lg py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right">
                        </div>
                        <div class="relative">
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">الخيار 4</label>
                            <input type="text" name="questions[\${questionCount}][options][]" required class="block w-full border border-slate-300 rounded-lg py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right">
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">الإجابة الصحيحة</label>
                        <select name="questions[\${questionCount}][correctOption]" required class="block w-full md:w-1/2 border border-slate-300 bg-white rounded-lg py-2.5 px-4 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm text-right">
                            <option value="0">الخيار 1</option>
                            <option value="1">الخيار 2</option>
                            <option value="2">الخيار 3</option>
                            <option value="3">الخيار 4</option>
                        </select>
                    </div>
                </div>
            `;
            questionsList.insertAdjacentHTML('beforeend', html);
            questionCount++;
            toggleFallback();
        }

        // Add first question automatically
        document.addEventListener('DOMContentLoaded', () => {
            addQuestion();
        });
    </script>

</body>
</html>
