<nav class="bg-indigo-700 text-white shadow-lg sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
            <div class="flex items-center space-x-3">
                <a href="/teacher/dashboard" class="text-2xl font-bold bg-white/20 p-2 rounded-lg">🎓</a>
                <span class="text-xl font-bold tracking-tight"><a href="/teacher/dashboard">QuizMaster Pro</a></span>
            </div>
            <div class="flex items-center space-x-6">
                <span class="text-sm font-medium opacity-80">Welcome, <%= teacher.name %></span>
                <a href="/auth/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200">Logout</a>
            </div>
        </div>
    </div>
</nav>

<main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Edit Quiz</h1>
            <p class="text-slate-500 mt-2">Update the details and questions for this quiz.</p>
        </div>
        <a href="/teacher/quizzes" class="text-indigo-600 hover:text-indigo-800 font-medium text-sm flex items-center">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Cancel
        </a>
    </div>

    <form action="/teacher/quizzes/<%= quiz.id %>/edit" method="POST" id="quizForm" class="space-y-8">
        <!-- Basic Settings -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-200 bg-slate-50">
                <h3 class="text-lg font-bold text-slate-900">Basic Configuration</h3>
            </div>
            <div class="p-6 space-y-6">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Quiz Title</label>
                    <input type="text" name="title" required placeholder="e.g., Final Exam - Math 101" value="<%= quiz.title %>"
                        class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow">
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Description</label>
                    <textarea name="description" rows="3" placeholder="Brief instructions for the students..."
                        class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow"><%= quiz.description %></textarea>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Start Time</label>
                        <input type="datetime-local" name="startTime" required 
                            value="<%= new Date(quiz.startTime).toISOString().slice(0, 16) %>"
                            class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">End Time</label>
                        <input type="datetime-local" name="endTime" required 
                            value="<%= new Date(quiz.endTime).toISOString().slice(0, 16) %>"
                            class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Duration (minutes)</label>
                        <div class="relative">
                            <input type="number" name="duration" required min="1" placeholder="60" value="<%= quiz.duration %>"
                                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow pl-10">
                            <svg class="w-5 h-5 text-slate-400 absolute left-3 top-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Total Marks</label>
                        <div class="relative">
                            <input type="number" name="totalMarks" required min="1" placeholder="100" value="<%= quiz.totalMarks %>"
                                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow pl-10">
                            <svg class="w-5 h-5 text-slate-400 absolute left-3 top-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Questions Section -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
                <h3 class="text-lg font-bold text-slate-900">Questions</h3>
                <span id="questionCount" class="bg-indigo-100 text-indigo-700 text-xs font-bold px-3 py-1 rounded-full"><%= quiz.questions.length %> Questions</span>
            </div>
            
            <div class="p-6">
                <div id="questionsContainer" class="space-y-8">
                    <% quiz.questions.forEach((q, index) => { %>
                    <!-- Existing Question Template -->
                    <div class="question-card bg-white border border-slate-200 rounded-xl p-6 relative group hover:border-indigo-300 transition-colors">
                        <button type="button" class="remove-btn absolute top-4 right-4 text-slate-400 hover:text-rose-500 opacity-0 group-hover:opacity-100 transition-opacity" title="Remove question">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </button>
                        
                        <div class="flex items-center mb-4">
                            <span class="q-number bg-indigo-600 text-white w-8 h-8 rounded-lg flex items-center justify-center font-bold text-sm mr-3 shadow-md"><%= index + 1 %></span>
                            <div class="grow">
                                <input type="text" name="questions[<%= index %>][text]" required placeholder="Enter the question text here..." value="<%= q.questionText %>"
                                    class="w-full px-4 py-2 border-b-2 border-slate-200 focus:border-indigo-500 bg-transparent text-lg font-medium outline-none transition-colors">
                            </div>
                        </div>

                        <div class="pl-11 grid grid-cols-2 gap-4">
                            <% for(let i=0; i<4; i++) { %>
                            <div class="relative flex items-center">
                                <input type="radio" name="questions[<%= index %>][correctOption]" value="<%= i %>" <%= q.correctOption === i ? 'checked' : '' %> required
                                    class="peer w-5 h-5 text-indigo-600 border-slate-300 focus:ring-indigo-500 focus:ring-2 ml-1 cursor-pointer">
                                <input type="text" name="questions[<%= index %>][options][]" required placeholder="Option <%= i + 1 %>" value="<%= q.options[i] %>"
                                    class="ml-3 w-full px-4 py-2 rounded-lg border border-slate-200 peer-checked:border-indigo-400 peer-checked:bg-indigo-50 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                            </div>
                            <% } %>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <button type="button" id="addQuestionBtn" class="mt-6 w-full py-4 border-2 border-dashed border-slate-300 rounded-xl text-slate-500 font-semibold hover:border-indigo-500 hover:text-indigo-600 hover:bg-indigo-50 transition-all flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    Add Another Question
                </button>
            </div>
        </div>

        <div class="flex justify-end pt-4 pb-20">
            <button type="submit" class="px-8 py-4 bg-indigo-600 text-white font-bold rounded-xl shadow-lg hover:bg-indigo-700 hover:shadow-indigo-500/30 hover:-translate-y-0.5 transition-all duration-200 flex items-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
                Save Changes to Quiz
            </button>
        </div>
    </form>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const container = document.getElementById('questionsContainer');
        const addBtn = document.getElementById('addQuestionBtn');
        const countBadge = document.getElementById('questionCount');
        
        let qCount = <%= quiz.questions.length %>;

        function updateIndices() {
            const cards = container.querySelectorAll('.question-card');
            cards.forEach((card, idx) => {
                card.querySelector('.q-number').textContent = idx + 1;
                
                const textInput = card.querySelector('input[type="text"][name$="[text]"]');
                textInput.name = `questions[${idx}][text]`;
                
                const radios = card.querySelectorAll('input[type="radio"]');
                radios.forEach(r => r.name = `questions[${idx}][correctOption]`);
                
                const optionInputs = card.querySelectorAll('input[type="text"][name*="[options]"]');
                optionInputs.forEach(opt => opt.name = `questions[${idx}][options][]`);
            });
            countBadge.textContent = `${cards.length} Questions`;
        }

        container.addEventListener('click', (e) => {
            const removeBtn = e.target.closest('.remove-btn');
            if(removeBtn) {
                const cards = container.querySelectorAll('.question-card');
                if(cards.length > 1) {
                    removeBtn.closest('.question-card').remove();
                    updateIndices();
                } else {
                    alert('A quiz must have at least one question.');
                }
            }
        });

        addBtn.addEventListener('click', () => {
            const currentCount = container.querySelectorAll('.question-card').length;
            const newIndex = currentCount;
            
            const template = `
                <div class="question-card bg-white border border-slate-200 rounded-xl p-6 relative group hover:border-indigo-300 transition-colors opacity-0 translate-y-4 shadow-sm">
                    <button type="button" class="remove-btn absolute top-4 right-4 text-slate-400 hover:text-rose-500 opacity-0 group-hover:opacity-100 transition-opacity" title="Remove question">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    </button>
                    
                    <div class="flex items-center mb-4">
                        <span class="q-number bg-indigo-600 text-white w-8 h-8 rounded-lg flex items-center justify-center font-bold text-sm mr-3 shadow-md">${newIndex + 1}</span>
                        <div class="flex-grow">
                            <input type="text" name="questions[${newIndex}][text]" required placeholder="Enter the question text here..."
                                class="w-full px-4 py-2 border-b-2 border-slate-200 focus:border-indigo-500 bg-transparent text-lg font-medium outline-none transition-colors">
                        </div>
                    </div>

                    <div class="pl-11 grid grid-cols-2 gap-4">
                        <div class="relative flex items-center">
                            <input type="radio" name="questions[${newIndex}][correctOption]" value="0" required
                                class="peer w-5 h-5 text-indigo-600 border-slate-300 focus:ring-indigo-500 focus:ring-2 ml-1 cursor-pointer">
                            <input type="text" name="questions[${newIndex}][options][]" required placeholder="Option 1"
                                class="ml-3 w-full px-4 py-2 rounded-lg border border-slate-200 peer-checked:border-indigo-400 peer-checked:bg-indigo-50 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                        </div>
                        <div class="relative flex items-center">
                            <input type="radio" name="questions[${newIndex}][correctOption]" value="1" required
                                class="peer w-5 h-5 text-indigo-600 border-slate-300 focus:ring-indigo-500 focus:ring-2 ml-1 cursor-pointer">
                            <input type="text" name="questions[${newIndex}][options][]" required placeholder="Option 2"
                                class="ml-3 w-full px-4 py-2 rounded-lg border border-slate-200 peer-checked:border-indigo-400 peer-checked:bg-indigo-50 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                        </div>
                        <div class="relative flex items-center">
                            <input type="radio" name="questions[${newIndex}][correctOption]" value="2" required
                                class="peer w-5 h-5 text-indigo-600 border-slate-300 focus:ring-indigo-500 focus:ring-2 ml-1 cursor-pointer">
                            <input type="text" name="questions[${newIndex}][options][]" required placeholder="Option 3"
                                class="ml-3 w-full px-4 py-2 rounded-lg border border-slate-200 peer-checked:border-indigo-400 peer-checked:bg-indigo-50 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                        </div>
                        <div class="relative flex items-center">
                            <input type="radio" name="questions[${newIndex}][correctOption]" value="3" required
                                class="peer w-5 h-5 text-indigo-600 border-slate-300 focus:ring-indigo-500 focus:ring-2 ml-1 cursor-pointer">
                            <input type="text" name="questions[${newIndex}][options][]" required placeholder="Option 4"
                                class="ml-3 w-full px-4 py-2 rounded-lg border border-slate-200 peer-checked:border-indigo-400 peer-checked:bg-indigo-50 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                        </div>
                    </div>
                </div>
            `;
            
            container.insertAdjacentHTML('beforeend', template);
            updateIndices();
            
            // Animate entrance
            requestAnimationFrame(() => {
                const newNode = container.lastElementChild;
                newNode.style.transition = 'all 0.4s cubic-bezier(0.4, 0, 0.2, 1)';
                newNode.classList.remove('opacity-0', 'translate-y-4');
                newNode.scrollIntoView({ behavior: 'smooth', block: 'center' });
            });
        });
    });
</script>
