<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Cairo', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 selection:bg-indigo-100 selection:text-indigo-900">

    <!-- Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3 space-x-reverse">
                <a href="/teacher/dashboard" class="flex items-center space-x-3 space-x-reverse">
                    <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center transform -rotate-3">
                        <svg class="w-5 h-5 text-white rotate-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
                    </div>
                    <h1 class="text-xl font-black tracking-tight text-slate-900">QuizMaster</h1>
                </a>
            </div>
            
            <div class="flex items-center space-x-6 space-x-reverse">
                <a href="/teacher/classes" class="text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors flex items-center">
                    <svg class="w-4 h-4 ml-1 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    العودة للفصول
                </a>
            </div>
        </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-12">
        <div class="flex flex-col md:flex-row-reverse md:items-end justify-between mb-8 pb-6 border-b border-slate-200">
            <div class="text-right">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-100 text-emerald-800 mb-2">
                    فصل
                </span>
                <h2 class="text-3xl font-black text-slate-900 tracking-tight"><%= classData.name %></h2>
                <% if (classData.description) { %>
                    <p class="text-slate-500 mt-2 text-sm"><%= classData.description %></p>
                <% } %>
            </div>
            <div class="mt-4 md:mt-0 flex items-center space-x-3 space-x-reverse">
                <a href="/teacher/classes/<%= classData.id %>/edit" class="inline-flex items-center justify-center px-4 py-2 border border-slate-300 text-sm font-bold rounded-lg text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                    تعديل الفصل
                </a>
                <form action="/teacher/classes/<%= classData.id %>/delete" method="POST" onsubmit="return confirm('هل تريد حذف هذا الفصل نهائياً؟');">
                    <button type="submit" class="inline-flex items-center justify-center px-4 py-2 border border-slate-300 text-sm font-bold rounded-lg text-rose-600 bg-white hover:bg-rose-50 hover:border-rose-200 focus:outline-none transition-colors">
                        حذف الفصل
                    </button>
                </form>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- Right Column: Students (Now on the right for RTL users, but let's keep the grid structure and adjust alignment) -->
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col h-full text-right">
                    <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center bg-slate-50 flex-row-reverse">
                        <h3 class="text-lg font-bold text-slate-900">الطلاب (<%= classData.students.length %>)</h3>
                    </div>
                    
                    <!-- Add Student Form -->
                    <div class="p-6 border-b border-slate-100 bg-white">
                        <form action="/teacher/classes/<%= classData.id %>/students/add" method="POST" class="flex flex-col sm:flex-row gap-4 flex-row-reverse">
                            <div class="grow">
                                <label class="sr-only" for="name">الاسم</label>
                                <input type="text" name="name" id="name" placeholder="اسم الطالب" required class="block w-full border border-slate-300 rounded-lg py-2 px-3 text-sm focus:ring-indigo-500 focus:border-indigo-500 text-right">
                            </div>
                            <div class="grow">
                                <label class="sr-only" for="phone">رقم الهاتف</label>
                                <input type="text" name="phone" id="phone" placeholder="رقم هاتف الطالب" required class="block w-full border border-slate-300 rounded-lg py-2 px-3 text-sm focus:ring-indigo-500 focus:border-indigo-500 text-right">
                            </div>
                            <div>
                                <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-bold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none shadow-sm transition-colors whitespace-nowrap flex-row-reverse">
                                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                    إضافة
                                </button>
                            </div>
                        </form>
                    </div>

                    <div class="grow overflow-auto">
                        <% if (classData.students.length === 0) { %>
                            <div class="p-8 text-center text-slate-500 text-sm">
                                لا يوجد طلاب مضافون بعد. استخدم النموذج أعلاه لإضافة الطلاب.
                            </div>
                        <% } else { %>
                            <ul class="divide-y divide-slate-100">
                                <% classData.students.forEach(student => { %>
                                    <li class="px-6 py-4 flex items-center justify-between hover:bg-slate-50 transition-colors group flex-row-reverse">
                                        <div class="text-right">
                                            <p class="text-sm font-bold text-slate-900"><%= student.name %></p>
                                            <p class="text-xs text-slate-500 mt-0.5"><%= student.phone %></p>
                                        </div>
                                        <div class="flex flex-col space-y-4">
                                            <a href="/teacher/students/<%= student.id %>" class="text-indigo-600 hover:text-indigo-800 text-sm font-bold transition-colors">عرض</a>
                                            <form action="/teacher/classes/<%= classData.id %>/students/<%= student.id %>/remove" method="POST" class="inline" onsubmit="return confirm('إزالة الطالب من الفصل؟');">
                                                <button type="submit" class="text-slate-400 hover:text-rose-600 transition-colors p-1">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                                </button>
                                            </form>
                                        </div>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Left Column: Quizzes -->
            <div class="space-y-6">
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden text-right">
                    <div class="px-6 py-5 border-b border-slate-100 bg-slate-50">
                        <h3 class="text-lg font-bold text-slate-900">الاختبارات المعينة (<%= classData.quizzes.length %>)</h3>
                    </div>
                    <div class="p-4">
                        <% if (classData.quizzes.length === 0) { %>
                            <div class="text-center text-slate-500 text-sm py-8">
                                لا توجد اختبارات معينة لهذا الفصل بعد.
                            </div>
                        <% } else { %>
                            <div class="space-y-3">
                                <% classData.quizzes.forEach(quiz => { %>
                                    <a href="/teacher/quizzes/<%= quiz.id %>" class="block p-4 rounded-xl border border-slate-100 bg-white hover:border-indigo-200 hover:shadow-sm transition-all group">
                                        <h4 class="font-bold text-slate-900 text-sm group-hover:text-indigo-600 transition-colors"><%= quiz.title %></h4>
                                        <div class="mt-2 flex items-center justify-between text-xs text-slate-500 flex-row-reverse">
                                            <span><%= quiz.duration %> دقيقة</span>
                                            <span><%= new Date(quiz.startTime).toLocaleDateString('ar-EG') %></span>
                                        </div>
                                    </a>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

        </div>
    </main>

</body>
</html>
