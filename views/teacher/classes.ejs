<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>body { font-family: "Inter", sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 font-sans selection:bg-indigo-100 selection:text-indigo-900">

    <!-- Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center transform -rotate-3">
                    <svg class="w-5 h-5 text-white rotate-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
                </div>
                <h1 class="text-xl font-black tracking-tight text-slate-900">QuizMaster</h1>
                <span class="px-2.5 py-1 bg-indigo-50 text-indigo-700 text-xs font-bold rounded-md ml-2 border border-indigo-100">Teacher</span>
            </div>
            
            <div class="flex items-center space-x-6">
                <a href="/teacher/dashboard" class="text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors">Dashboard</a>
                <a href="/teacher/quizzes" class="text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors">Quizzes</a>
                <a href="/teacher/classes" class="text-sm font-bold text-slate-900 text-indigo-600">Classes</a>
                <div class="h-6 w-px bg-slate-200"></div>
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center text-slate-600 font-bold border border-slate-200">
                        <%= teacher.name ? teacher.name.charAt(0).toUpperCase() : 'T' %>
                    </div>
                </div>
                <a href="/auth/logout" class="text-sm font-bold text-slate-500 hover:text-rose-600 transition-colors flex items-center group">
                    <span>Logout</span>
                    <svg class="w-4 h-4 ml-1.5 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                </a>
            </div>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-12">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 pb-6 border-b border-slate-200">
            <div>
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">Manage Classes</h2>
                <p class="text-slate-500 mt-2 text-lg">Create and organize your student classes.</p>
            </div>
            <div class="mt-4 md:mt-0 flex items-center space-x-4">
                <div class="relative">
                    <svg class="w-5 h-5 absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    <input type="text" id="searchInput" placeholder="Search classes..." class="pl-10 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 w-64">
                </div>
                <a href="/teacher/classes/create" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-bold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 shadow-sm transition-colors">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    New Class
                </a>
            </div>
        </div>

        <% if (classes.length === 0) { %>
            <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center">
                <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                </div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">No classes yet</h3>
                <p class="text-slate-500 max-w-sm mx-auto mb-6">Create classes to organize your students and assign quizzes to specific groups.</p>
                <a href="/teacher/classes/create" class="inline-flex items-center justify-center px-5 py-2.5 border border-transparent text-sm font-bold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none shadow-sm transition-colors">
                    Create your first class
                </a>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="classesGrid">
                <% classes.forEach(c => { %>
                    <div class="bg-white rounded-2xl border border-slate-200 p-6 flex flex-col hover:shadow-md hover:border-indigo-300 transition-all duration-200 class-card">
                        <div class="flex justify-between items-start mb-4">
                            <h3 class="text-xl font-bold text-slate-900 class-name"><%= c.name %></h3>
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-800">
                                <%= c._count.students %> Students
                            </span>
                        </div>
                        
                        <div class="flex items-center justify-between mt-auto pt-4 border-t border-slate-100">
                            <div class="flex space-x-2">
                                <a href="/teacher/classes/<%= c.id %>" class="inline-flex items-center justify-center px-3 py-1.5 border border-slate-300 text-xs font-bold rounded-md text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                                    Show Details
                                </a>
                                <form action="/teacher/classes/<%= c.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this class? Students will not be deleted.');" class="inline">
                                    <button type="submit" class="inline-flex items-center justify-center px-3 py-1.5 border border-transparent text-xs font-bold rounded-md text-rose-700 bg-rose-50 hover:bg-rose-100 transition-colors">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <script>
        // Simple search functionality
        document.getElementById('searchInput')?.addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const cards = document.querySelectorAll('.class-card');
            
            cards.forEach(card => {
                const name = card.querySelector('.class-name').textContent.toLowerCase();
                if (name.includes(searchTerm)) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    </script>
</body>
</html>
