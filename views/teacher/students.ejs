<nav class="bg-indigo-700 text-white shadow-lg sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
            <div class="flex items-center space-x-3">
                <a href="/teacher/dashboard" class="text-2xl font-bold bg-white/20 p-2 rounded-lg">🎓</a>
                <span class="text-xl font-bold tracking-tight">QuizMaster Pro</span>
            </div>
            <div class="flex items-center space-x-6">
                <span class="text-sm font-medium opacity-80">Welcome, <%= teacher.name %></span>
                <a href="/auth/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200">Logout</a>
            </div>
        </div>
    </div>
</nav>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10" x-data="{ showModal: false, showImportModal: false }">
    <div class="mb-10 flex justify-between items-end">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Student Management</h1>
            <p class="text-slate-500 mt-2">Add students manually or bulk import via CSV.</p>
        </div>
        <div class="flex space-x-4">
            <button @click="showImportModal = true" class="inline-flex items-center px-6 py-3 border border-indigo-600 text-indigo-600 font-semibold rounded-xl hover:bg-indigo-50 transition-all duration-200 shadow-sm">
                Import CSV
            </button>
            <button @click="showModal = true" class="inline-flex items-center px-6 py-3 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 transition-all duration-200 shadow-md">
                Add Student
            </button>
        </div>
    </div>

    <!-- Students Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-50 text-slate-500 text-xs font-bold uppercase tracking-wider">
                    <tr>
                        <th class="px-8 py-4">Name</th>
                        <th class="px-8 py-4">Phone</th>
                        <th class="px-8 py-4">Group</th>
                        <th class="px-8 py-4">Added On</th>
                        <th class="px-8 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <% students.forEach(student => { %>
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-8 py-6 font-semibold text-slate-900"><%= student.name %></td>
                        <td class="px-8 py-6 text-slate-600"><%= student.phone %></td>
                        <td class="px-8 py-6 text-slate-600"><%= student.groupName %></td>
                        <td class="px-8 py-6 text-slate-600"><%= new Date(student.createdAt).toLocaleDateString() %></td>
                        <td class="px-8 py-6 text-right">
                            <button class="text-rose-600 hover:text-rose-800 font-bold px-4 py-2 hover:bg-rose-50 rounded-lg transition-all">Delete</button>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (students.length === 0) { %>
                    <tr>
                        <td colspan="5" class="px-8 py-12 text-center text-slate-500">
                            No students found. Add your first student to get started!
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Add Modal -->
    <div x-show="showModal" class="fixed inset-0 z-50 overflow-y-auto" style="display: none;">
        <div class="flex items-center justify-center min-h-screen px-4">
            <div class="fixed inset-0 bg-slate-900 opacity-50 transition-opacity" @click="showModal = false"></div>
            <div class="bg-white rounded-2xl overflow-hidden shadow-2xl z-50 w-full max-w-md transform transition-all border border-slate-100">
                <div class="px-8 py-6 border-b border-slate-100 flex justify-between items-center">
                    <h3 class="text-lg font-bold text-slate-900">Add New Student</h3>
                    <button @click="showModal = false" class="text-slate-400 hover:text-slate-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>
                <form action="/teacher/students/add" method="POST" class="p-8 space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-slate-700">Full Name</label>
                        <input type="text" name="name" required class="mt-1 block w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700">Phone Number</label>
                        <input type="text" name="phone" required class="mt-1 block w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all" placeholder="+1234567890">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700">Group Name</label>
                        <input type="text" name="groupName" required class="mt-1 block w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all">
                    </div>
                    <button type="submit" class="w-full bg-indigo-600 text-white font-bold py-4 rounded-xl hover:bg-indigo-700 shadow-md transition-all">
                        Add Student
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Import Modal -->
    <div x-show="showImportModal" class="fixed inset-0 z-50 overflow-y-auto" style="display: none;">
        <div class="flex items-center justify-center min-h-screen px-4">
            <div class="fixed inset-0 bg-slate-900 opacity-50 transition-opacity" @click="showImportModal = false"></div>
            <div class="bg-white rounded-2xl overflow-hidden shadow-2xl z-50 w-full max-w-md transform transition-all border border-slate-100">
                <div class="px-8 py-6 border-b border-slate-100 flex justify-between items-center">
                    <h3 class="text-lg font-bold text-slate-900">Import Students</h3>
                    <button @click="showImportModal = false" class="text-slate-400 hover:text-slate-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>
                <form action="/teacher/students/import" method="POST" enctype="multipart/form-data" class="p-8 space-y-6">
                    <div class="text-center p-8 border-2 border-dashed border-slate-200 rounded-2xl bg-slate-50">
                        <p class="text-sm text-slate-600 mb-4">Upload a CSV file with headers: <br><code class="bg-slate-200 px-2 py-1 rounded">name, phone, groupName</code></p>
                        <input type="file" name="csvFile" accept=".csv" required class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer">
                    </div>
                    <button type="submit" class="w-full bg-indigo-600 text-white font-bold py-4 rounded-xl hover:bg-indigo-700 shadow-md transition-all">
                        Start Import
                    </button>
                </form>
            </div>
        </div>
    </div>
</main>
