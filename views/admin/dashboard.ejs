<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>body { font-family: "Cairo", sans-serif; }</style>
</head>
<body class="bg-slate-100 min-h-screen">
    <div class="flex min-h-screen">
        <%- include('../partials/admin_sidebar', { active: 'dashboard' }) %>

        <!-- Main Content -->
        <main class="flex-1 mr-64">
            <div class="p-8">
                <div class="mb-8">
                    <h2 class="text-3xl font-black text-slate-900 tracking-tight">لوحة التحكم</h2>
                    <p class="text-slate-500 mt-1">مرحباً بك، <%= admin.name || 'مدير' %>! نظرة عامة على النظام.</p>
                </div>

                <!-- Stats Cards -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-5">
                    <!-- Teachers -->
                    <a href="/admin/teachers" class="block bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-lg hover:border-violet-300 transition-all duration-200 group">
                        <div class="flex items-center justify-between mb-3 flex-row-reverse">
                            <div class="w-12 h-12 bg-violet-50 rounded-xl flex items-center justify-center text-violet-600 group-hover:scale-110 transition-transform">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
                            </div>
                        </div>
                        <h3 class="text-4xl font-black text-slate-900"><%= stats.teachers %></h3>
                        <p class="text-sm font-medium text-slate-500 mt-1">إجمالي المعلمين</p>
                    </a>

                    <!-- Students -->
                    <a href="/admin/students" class="block bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-lg hover:border-blue-300 transition-all duration-200 group">
                        <div class="flex items-center justify-between mb-3 flex-row-reverse">
                            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 group-hover:scale-110 transition-transform">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                            </div>
                        </div>
                        <h3 class="text-4xl font-black text-slate-900"><%= stats.students %></h3>
                        <p class="text-sm font-medium text-slate-500 mt-1">إجمالي الطلاب</p>
                    </a>

                    <!-- Quizzes -->
                    <a href="/admin/quizzes" class="block bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-lg hover:border-emerald-300 transition-all duration-200 group">
                        <div class="flex items-center justify-between mb-3 flex-row-reverse">
                            <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600 group-hover:scale-110 transition-transform">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            </div>
                        </div>
                        <h3 class="text-4xl font-black text-slate-900"><%= stats.quizzes %></h3>
                        <p class="text-sm font-medium text-slate-500 mt-1">إجمالي الاختبارات</p>
                    </a>

                    <!-- Classes -->
                    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm group">
                        <div class="flex items-center justify-between mb-3 flex-row-reverse">
                            <div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center text-amber-600">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                            </div>
                        </div>
                        <h3 class="text-4xl font-black text-slate-900"><%= stats.classes %></h3>
                        <p class="text-sm font-medium text-slate-500 mt-1">إجمالي الفصول</p>
                    </div>

                    <!-- Subscriptions -->
                    <a href="/admin/subscriptions" class="block bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-lg hover:border-rose-300 transition-all duration-200 group">
                        <div class="flex items-center justify-between mb-3 flex-row-reverse">
                            <div class="w-12 h-12 bg-rose-50 rounded-xl flex items-center justify-center text-rose-600 group-hover:scale-110 transition-transform">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                            </div>
                        </div>
                        <h3 class="text-4xl font-black text-slate-900"><%= stats.subscriptions %></h3>
                        <p class="text-sm font-medium text-slate-500 mt-1">إجمالي الاشتراكات</p>
                    </a>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
