<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>body { font-family: "Cairo", sans-serif; }</style>
</head>
<body class="bg-slate-100 min-h-screen">
    <div class="flex min-h-screen">
        <%- include('_sidebar', { active: 'students' }) %>
        <main class="flex-1 mr-64">
            <div class="p-8">
                <!-- Breadcrumb -->
                <div class="mb-6">
                    <a href="/admin/students" class="text-violet-600 hover:text-violet-800 text-sm font-bold">← العودة للطلاب</a>
                </div>

                <!-- Student Header -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8 mb-6">
                    <div class="flex items-start gap-6">
                        <div class="w-20 h-20 bg-linear-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center text-white font-black text-3xl shadow-lg shadow-blue-500/20">
                            <%= student.name.charAt(0).toUpperCase() %>
                        </div>
                        <div class="flex-1">
                            <h2 class="text-2xl font-black text-slate-900"><%= student.name %></h2>
                            <div class="flex flex-wrap gap-4 mt-3 text-sm text-slate-500">
                                <span class="flex items-center gap-1.5">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                    <span dir="ltr"><%= student.phone %></span>
                                </span>
                                <% if (student.parentPhone) { %>
                                <span class="flex items-center gap-1.5">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                    هاتف الوالد: <span dir="ltr"><%= student.parentPhone %></span>
                                </span>
                                <% } %>
                                <% if (student.class) { %>
                                <span class="flex items-center gap-1.5">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                                    <a href="/admin/classes/<%= student.class.id %>" class="text-violet-600 hover:text-violet-800 font-medium"><%= student.class.name %></a>
                                </span>
                                <% } %>
                            </div>
                            <p class="text-xs text-slate-400 mt-2">تاريخ التسجيل: <%= new Date(student.createdAt).toLocaleDateString('ar-EG', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
                        </div>
                    </div>
                </div>

                <!-- Analysis Cards -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-6">
                    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
                        <p class="text-sm font-medium text-slate-500 mb-1">أعلى درجة</p>
                        <p class="text-2xl font-black text-emerald-600"><%= analysis.bestScore %></p>
                    </div>
                    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
                        <p class="text-sm font-medium text-slate-500 mb-1">أقل درجة</p>
                        <p class="text-2xl font-black text-rose-600"><%= analysis.worstScore %></p>
                    </div>
                    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
                        <p class="text-sm font-medium text-slate-500 mb-1">متوسط الدرجات</p>
                        <p class="text-2xl font-black text-violet-600"><%= analysis.avgScore %></p>
                    </div>
                </div>

                <!-- Quiz Results Table -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h3 class="font-bold text-slate-900">الاختبارات المقدمة (<%= analysis.totalSubmissions %>)</h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="bg-slate-50 border-b border-slate-200">
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">الاختبار</th>
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">المعلم</th>
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">الدرجة</th>
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">النسبة</th>
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">التاريخ</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <% if (student.submissions.length === 0) { %>
                                <tr><td colspan="5" class="px-6 py-12 text-center text-slate-400">لم يقدم الطالب أي اختبارات بعد</td></tr>
                                <% } %>
                                <% student.submissions.forEach(sub => { %>
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4 font-bold text-slate-900 text-sm"><%= sub.quiz.title %></td>
                                    <td class="px-6 py-4">
                                        <a href="/admin/teachers/<%= sub.quiz.teacher.id %>" class="text-violet-600 hover:text-violet-800 text-sm"><%= sub.quiz.teacher.name || sub.quiz.teacher.email %></a>
                                    </td>
                                    <td class="px-6 py-4 text-sm"><%= sub.score %> / <%= sub.quiz.totalMarks %></td>
                                    <td class="px-6 py-4">
                                        <% const pct = sub.quiz.totalMarks > 0 ? ((sub.score / sub.quiz.totalMarks) * 100).toFixed(1) : '0'; %>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold <%= parseFloat(pct) >= 50 ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
                                            <%= pct %>%
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-slate-500 text-sm"><%= sub.submittedAt ? new Date(sub.submittedAt).toLocaleDateString('ar-EG') : 'قيد التقديم' %></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
