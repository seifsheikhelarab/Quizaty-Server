<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="/css/output.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>body { font-family: "Cairo", sans-serif; }</style>
</head>
<body class="bg-slate-100 min-h-screen">
    <div class="flex min-h-screen">
        <%- include('_sidebar', { active: 'teachers' }) %>
        <main class="flex-1 mr-64">
            <div class="p-8">
                <!-- Breadcrumb -->
                <div class="mb-6">
                    <a href="/admin/teachers" class="text-violet-600 hover:text-violet-800 text-sm font-bold">← العودة للمعلمين</a>
                </div>

                <!-- Teacher Header -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8 mb-6">
                    <div class="flex items-start gap-6">
                        <div class="w-20 h-20 bg-linear-to-br from-violet-500 to-violet-600 rounded-2xl flex items-center justify-center text-white font-black text-3xl shadow-lg shadow-violet-500/20">
                            <%= teacher.name ? teacher.name.charAt(0).toUpperCase() : 'م' %>
                        </div>
                        <div class="flex-1">
                            <h2 class="text-2xl font-black text-slate-900"><%= teacher.name || 'بدون اسم' %></h2>
                            <div class="flex flex-wrap gap-4 mt-3 text-sm text-slate-500">
                                <span class="flex items-center gap-1.5">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                    <%= teacher.email %>
                                </span>
                                <% if (teacher.phone) { %>
                                <span class="flex items-center gap-1.5">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                    <span dir="ltr"><%= teacher.phone %></span>
                                </span>
                                <% } %>
                            </div>
                            <p class="text-xs text-slate-400 mt-2">تاريخ التسجيل: <%= new Date(teacher.createdAt).toLocaleDateString('ar-EG', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
                        </div>
                    </div>
                </div>

                <!-- Stats Row -->
                <div class="grid grid-cols-1 sm:grid-cols-4 gap-5 mb-6">
                    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
                        <p class="text-sm font-medium text-slate-500 mb-1">الاختبارات</p>
                        <p class="text-2xl font-black text-violet-600"><%= teacher.quizzes.length %></p>
                    </div>
                    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
                        <p class="text-sm font-medium text-slate-500 mb-1">الفصول</p>
                        <p class="text-2xl font-black text-blue-600"><%= teacher.classes.length %></p>
                    </div>
                    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
                        <p class="text-sm font-medium text-slate-500 mb-1">الطلاب</p>
                        <p class="text-2xl font-black text-emerald-600"><%= totalStudents %></p>
                    </div>
                    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
                        <p class="text-sm font-medium text-slate-500 mb-1">مستوى الاشتراك</p>
                        <% if (activeSubscription) { %>
                        <p class="text-2xl font-black text-amber-600"><%= activeSubscription.tier %></p>
                        <% } else { %>
                        <p class="text-2xl font-black text-slate-400">بدون</p>
                        <% } %>
                    </div>
                </div>

                <!-- Subscription Management -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 mb-6" x-data="{ showUpgrade: false, showExtend: false }">
                    <h3 class="font-bold text-slate-900 text-lg mb-4">إدارة الاشتراك</h3>

                    <% if (activeSubscription) { %>
                    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-4">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-sm font-bold text-amber-800">اشتراك نشط: <%= activeSubscription.tier %></p>
                                <% if (activeSubscription.expiresAt) { %>
                                <p class="text-xs text-amber-600 mt-1">ينتهي في: <%= new Date(activeSubscription.expiresAt).toLocaleDateString('ar-EG', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
                                <% } %>
                            </div>
                            <span class="px-3 py-1 bg-emerald-100 text-emerald-700 text-xs font-bold rounded-full">نشط</span>
                        </div>
                    </div>
                    <% } %>

                    <div class="flex flex-wrap gap-3">
                        <button @click="showUpgrade = !showUpgrade; showExtend = false" class="px-5 py-2.5 bg-violet-600 hover:bg-violet-500 text-white font-bold rounded-xl text-sm transition-all shadow-sm">
                            ترقية الاشتراك
                        </button>
                        <% if (activeSubscription) { %>
                        <button @click="showExtend = !showExtend; showUpgrade = false" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl text-sm transition-all shadow-sm">
                            تمديد الاشتراك
                        </button>
                        <form method="POST" action="/admin/teachers/<%= teacher.id %>/subscription" class="inline" onsubmit="return confirm('هل أنت متأكد من إلغاء الاشتراك؟')">
                            <input type="hidden" name="action" value="cancel" />
                            <button type="submit" class="px-5 py-2.5 bg-rose-600 hover:bg-rose-500 text-white font-bold rounded-xl text-sm transition-all shadow-sm">
                                إلغاء الاشتراك
                            </button>
                        </form>
                        <% } %>
                    </div>

                    <!-- Upgrade Form -->
                    <div x-show="showUpgrade" x-transition class="mt-4 bg-slate-50 rounded-xl p-4 border border-slate-200">
                        <form method="POST" action="/admin/teachers/<%= teacher.id %>/subscription" class="flex items-end gap-3">
                            <input type="hidden" name="action" value="upgrade" />
                            <div class="flex-1">
                                <label class="block text-sm font-bold text-slate-700 mb-1">المستوى</label>
                                <select name="tier" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm">
                                    <option value="BASIC">BASIC</option>
                                    <option value="PREMIUM" selected>PREMIUM</option>
                                </select>
                            </div>
                            <div class="flex-1">
                                <label class="block text-sm font-bold text-slate-700 mb-1">المدة (أشهر)</label>
                                <input type="number" name="months" value="1" min="1" max="24" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm" />
                            </div>
                            <button type="submit" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white font-bold rounded-lg text-sm transition-all">
                                تأكيد
                            </button>
                        </form>
                    </div>

                    <!-- Extend Form -->
                    <div x-show="showExtend" x-transition class="mt-4 bg-slate-50 rounded-xl p-4 border border-slate-200">
                        <form method="POST" action="/admin/teachers/<%= teacher.id %>/subscription" class="flex items-end gap-3">
                            <input type="hidden" name="action" value="extend" />
                            <div class="flex-1">
                                <label class="block text-sm font-bold text-slate-700 mb-1">تمديد بـ (أشهر)</label>
                                <input type="number" name="months" value="1" min="1" max="24" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm" />
                            </div>
                            <button type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-lg text-sm transition-all">
                                تأكيد التمديد
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Classes -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden mb-6">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h3 class="font-bold text-slate-900">الفصول (<%= teacher.classes.length %>)</h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="bg-slate-50 border-b border-slate-200">
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">الفصل</th>
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">عدد الطلاب</th>
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">إجراءات</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <% if (teacher.classes.length === 0) { %>
                                <tr><td colspan="3" class="px-6 py-8 text-center text-slate-400">لا توجد فصول</td></tr>
                                <% } %>
                                <% teacher.classes.forEach(cls => { %>
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-3 font-bold text-slate-900 text-sm"><%= cls.name %></td>
                                    <td class="px-6 py-3"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-blue-100 text-blue-700"><%= cls._count.students %></span></td>
                                    <td class="px-6 py-3"><a href="/admin/classes/<%= cls.id %>" class="text-violet-600 hover:text-violet-800 text-sm font-bold">عرض</a></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Recent Quizzes -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h3 class="font-bold text-slate-900">أحدث الاختبارات (<%= teacher.quizzes.length %>)</h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="bg-slate-50 border-b border-slate-200">
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">العنوان</th>
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">الأسئلة</th>
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">الردود</th>
                                    <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase">التاريخ</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <% if (teacher.quizzes.length === 0) { %>
                                <tr><td colspan="4" class="px-6 py-8 text-center text-slate-400">لا توجد اختبارات</td></tr>
                                <% } %>
                                <% teacher.quizzes.forEach(quiz => { %>
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-3 font-bold text-slate-900 text-sm"><%= quiz.title %></td>
                                    <td class="px-6 py-3"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-indigo-100 text-indigo-700"><%= quiz._count.questions %></span></td>
                                    <td class="px-6 py-3"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-100 text-emerald-700"><%= quiz._count.submissions %></span></td>
                                    <td class="px-6 py-3 text-slate-500 text-sm"><%= new Date(quiz.createdAt).toLocaleDateString('ar-EG') %></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
