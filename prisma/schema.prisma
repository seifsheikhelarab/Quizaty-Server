generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Teacher {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String?
  phone         String?
  quizzes       Quiz[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  classes       Class[]
  subscriptions Subscription[]
}

model Student {
  id          String       @id @default(cuid())
  name        String
  phone       String       @unique
  telegramId  String?      @unique
  parentPhone String?
  submissions Submission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  class       Class?       @relation(fields: [classId], references: [id])
  classId     String?
  password    String?
  shortCode   String?

  @@unique([classId, shortCode])
}

model Quiz {
  id          String       @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  duration    Int // Duration in minutes
  totalMarks  Int
  teacherId   String
  teacher     Teacher      @relation(fields: [teacherId], references: [id])
  questions   Question[]
  submissions Submission[]
  classes     Class[]
  showResults Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Question {
  id            String   @id @default(cuid())
  questionText  String
  options       String[] // Array of strings
  correctOption Int // Index of the correct option
  imageUrl      String? // Optional image illustration
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id])
}

model Submission {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id])
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  score       Int       @default(0)
  answers     Json? // Optional: store student answers
  violations  Json? // Optional: store cheating violations
}

model Class {
  id          String    @id @default(cuid())
  name        String
  description String?
  teacherId   String
  teacher     Teacher   @relation(fields: [teacherId], references: [id])
  students    Student[]
  quizzes     Quiz[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum SubscriptionTier {
  FREE_TRIAL
  BASIC
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  active
  cancelled
  expired
}

model Subscription {
  id        String             @id @default(cuid())
  teacherId String
  teacher   Teacher            @relation(fields: [teacherId], references: [id])
  tier      SubscriptionTier
  status    SubscriptionStatus @default(active)
  startedAt DateTime           @default(now())
  expiresAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
